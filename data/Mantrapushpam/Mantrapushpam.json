{
  "title": "ಮಂತ್ರಪುಷ್ಪಂ",
  "content": [
    {
      "type": "subheading",
      "title": "ರಾಮಾಯಣಂ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ತಪಸ್ವಾಧ್ಯಾಯ ನಿರತಮ್ ತಪಸ್ವೀ ವಾಗ್ವಿದಾಂ ವರಮ್ ।",
        "ನಾರದಂ ಪರಿಪಪ್ರಚ್ಛ ವಾಲ್ಮೀಕೀರ್ಮುನಿ ಪುಙ್ಗವಮ್ |||"
      ]
    },  
    {
      "type": "paragraph",
      "lines": [
        "ಇಚ್ಛಾ ಮೋಹಿ ಮಹಾಬಾಹುಂ ರಘುವೀರಂ ಮಹಾಬಲಂ ।",
        "ಗಜೇನ ಮಹತಾ ಯಾಂತಂ ರಾಮಂ ಛತ್ರಾ ವೃತಾನನಂ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ತಂ ದೃಷ್ಟ್ವಾ ಶತ್ರು ಹಂತಾರಂ ಮಹರ್ಷೀಣಾಂ ಸುಖಾವಹಂ ",
        "ಬಭೂವ ಹೃಷ್ಟಾ ವೈದೇಹೀ ಭರ್ತಾರಂ ಪರಿಷಸ್ವಜೇ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ತತಸ್ಸ ಪ್ರಯತೋ ವೃಧ್ಧೋ ವಸಿಷ್ಠೋ ಬ್ರಾಹ್ಮಣೈಸ್ಸಹ",
        "ರಾಮಂ ರತ್ನಮಯೇ ಪೀಠೇ ಸಹಸೀತಂ ನ್ಯವೇಶಯತ್ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವಸಿಷ್ಠೋ ವಾಮದೇವಶ್ಚ ಜಾಬಾಲಿರಥ ಕಾಶ್ಯಪಃ",
        "ಕಾತ್ಯಾಯನಸ್ಸುಯಜ್ಞಶ್ಚ ಗೌತಮೋ ವಿಜಯಸ್ತಥಾ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅಭ್ಯಷಿಂಚನ್ ನರವ್ಯಾಘ್ರಂ ಪ್ರಸನ್ನೇನ ಸುಗಂಧಿನಾ",
        "ಸಲಿಲೇನ ಸಹಸ್ರಾಕ್ಷಂ ವಸವೋ ವಾಸವಂ ಯಥಾ||"
      ]
    },
    {
      "type": "subheading",
      "title": "ಮಹಾಭಾರತಂ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ನಮಾಮಿ ಸರ್ವ ಲೋಕಾನಾಂ ಜನನೀಂ ಅಬ್ಬಿಸಂಭವಾಂ।",
        "ಶ್ರಿಯಮುನ್ನಿದ್ರ ಪದ್ಮಾಕ್ಷೀಂ ವಿಷ್ಣುವಕ್ಷಃಸ್ಥಲೇ ಸ್ಥಿತಾಂ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಇದಂ ಮಯಾ ತೇ ಪರಿಕೀರ್ತಿತಂ ಮಹತ್",
        "ಶ್ರೀಕೃಷ್ಣಮಾಹಾತ್ಮ್ಯಾ ಅಪಾರಮದ್ಭುತಂ",
        "ಶೃಣ್ವನ್ ಪಠನ್ನಾಶು ಸಮಾಪ್ನುಯಾತ್ ಫಲಂ",
        "ಯಚ್ಚಾಪಿ ಲೋಕೇಷು ಸುದರ್ಲಭಂ ಮಹತ್ ।।"
      ]
    },
    {
      "type": "subheading",
      "title": "ಭಾಗವತಮ್"
    },
    {
      "type": "paragraph",
      "lines": [
        "ತಾಸಾಮಾವಿರಭೂಚ್ಚೌರಿ: ಸ್ವಯಮಾನ ಮುಖಾಂಬುಜ:।",
        "ಪೀತಾಂಬರಧರ: ಸ್ರಗ್ವೀ ಸಾಕ್ಷಾತ್ ಮನ್ಮಥ ಮನ್ಮಥ: ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಯೋಗಿಂದ್ರಾಯ ನಮಸ್ತಸ್ತ್ಮೈ ಶುಕಾಯ ಬ್ರಹ್ಮರೂಪಿಣೇ ।",
        "ಸಂಸಾರ ಸರ್ಪದಷ್ಟಂ ಯೋ ವಿಷ್ಣುರಾತಮಮೂಮುಚತ್"
      ]
    },
    {
      "type": "subheading",
      "title": "ಭಗವದ್ಗೀತೆ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ಯತ್ರಯೋಗೇಶ್ವರಃ ಕೃಷ್ಣೋ ಯತ್ರ ಪಾರ್ಥೋ ಧನುರ್ಧರಃ।", 
        "ತತ್ರಶ್ರೀರ್ವಿಜಯೋ ಭೂತಿಃ ಧೃವಾನೀತಿರ್ಮತಿರ್ಮಮ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸರ್ವಧರ್ಮಾನ್ ಪರಿತ್ಯಜ್ಯ ಮಾಮೇಕಂ ಶರಣಂ ವ್ರಜ ।",
        "ಅಹಂತ್ವಾ ಸರ್ವ ಪಾಪೇಭ್ಯೋ ಮೋಕ್ಷ್ಯಯಿಷ್ಯಾಮಿ ಮಾಶುಚಃ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಧರ್ಮಕ್ಷೇತ್ರೇ ಕುರುಕ್ಷೇತ್ರೇ ಸಮವೇತಾ ಯುಯುತ್ಸವಃ ।",
        "ಮಾಮಕಾಃ ಪಾಣ್ಡವಾಚೈವ ಕಿಮಕುರ್ವತ ಸಞ್ಜಯ ॥"
      ]
    },
    {
      "type": "subheading",
      "title": "ವಿಷ್ಣುಪುರಾಣಂ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ಏಷ ನಾರಾಯಣ ಶ್ರೀಮಾನ್ ಕ್ಷೀರಾರ್ಣವ ನಿಕೇತನ: ।",
        "ನಾಗ ಪರ್ಯಂಕಮುತ್ಸಜ್ಯ ಹ್ಯಾಗತೋ ಮಧುರಾ ಪುರೀಂ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವೈಕುಂಠೇತು ಪರೇ ಲೋಕೇ ಶ್ರಿಯಾ ಸಾರ್ಥಂ ಜಗತ್ಪತಿಃ ।",
        "ಆಸ್ಥೇ ವಿಷ್ಣುರಚಿಂತ್ಯಾತ್ಮಾ ಭಕ್ತೈರ್ಭಾಗವತೈಸ್ಸಹ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಇತಿ ವಿವಿಧಮಜಸ್ಯ ಯಸ್ಯ ರೂಪಂ ಪ್ರಕೃತಿಪರಾತ್ಮಮಯಂ ಸನಾತನಸ್ಯ ।",
        "ಸ ದಿಶತು ಭಗವಾನಶೇಷಪುಂಸಾಂ ಹರಿರಪಜನ್ಮಜರಾದಿಕಾಂ ಸಮೃದ್ಧಿಂ||"
      ]
    },
    {
      "type": "subheading",
      "title": "ವಿಷ್ಣುಪುರಾಣಂ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ಮಾಯಾವಿ ಪರಮಾನಂದಂ ತ್ಯಕ್ತಾ ವೈಕುಂಠಮುತ್ತಮಂ।",
        "ಸ್ವಾಮಿಪುಷ್ಕರಿಣೀ ತೀರೇ ರಮಯಾ ಸಹ ಮೋದತೇ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವೈಕುಂಠವಾಸಿನಃ ಸರ್ವೇಶೇಷ ಶೇಷಾಸನಾದಯಃ।",
        "ತಿರ್ಯಕ್ ಸ್ಥಾವರಜನ್ಮಾನಿ ಶ್ರಯಂತೇ ಯದುಭೂಧರೇ ||"
      ]
    },
    {
      "type": "subheading",
      "title": "ಸ್ತೋತ್ರರತ್ನ"
    },
    {
      "type": "paragraph", 
      "lines": [
        "ಕದಾ ಪುನ: ಶಂಖ ರಥಾಂಗ ಕಲ್ಪಕ ಧ್ವಜಾರವಿಂದಾಂಕುಶ ವಜ್ರ ಲಾಂಛನಂ।",
        "ತ್ರಿವಿಕ್ರಮ ತ್ವತ್ ಚರಣಾಂಬುಜ ದ್ವಯಂ ಮದೀಯ ಮೂರ್ಧಾನಂ ಅಲಂಕರಿಷ್ಯತಿ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಆಕೃತ್ರಿಮತ್ವಚ್ಚರಣಾರವಿಂದ ಪ್ರೇಮ ಪ್ರಕರ್ಷಾವಧಿಂ ಆತ್ಮವಂತಂ",
        "ಪಿತಾಮಹಂ ನಾಥಮುನಿಂ ವಿಲೋಕ್ಯ ಪ್ರಸೀದ ಮದ್ವೃತ್ತಮ ಚಿಂತಯಿತ್ವಾ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನ ಧರ್ಮ ನಿಷ್ಟೋಽಸ್ಮಿ ನ ಚಾತ್ಮವೇದೀ, ನ ಭಕ್ತಿಮಾನ್ ತ್ವಚ್ಚರಣಾರವಿಂದೇ",
        "ಅಕಿಂಚನೋಽನ್ಯಗತಿ: ಶರಣ್ಯ,  ತ್ವತ್ಪಾದಮೂಲಂ ಶರಣಂ ಪ್ರಪದ್ಯೆ ||"
      ]
    },
    {
      "type": "subheading",
      "title": "ತಿರುವಂದಾದಿ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶೆನ್ರಾಲ್ ಕುಡೈಯಾಂ, ಇರುಂದಾಲ್ ಶಿಂಗಾಸನಮಾಂ।",
        "ನಿನ್ರಾಲ್ ಮರವಡಿಯಾಂ ನೀಳ್ ಕಡಲುಳ್",
        "ಪುಣೈಯಾಮ್‌ ಮಣಿವಿಳಕ್ಕಾಮ್‌, ಪೂಂಪಟ್ಟಾಂ ಪುಲ್ಗಂ",
        "ಅಣೈಯಾಮ್ ತಿರುಮಾರ್ಕ್ಕರವು"
      ]
    },
    {
      "type": "subheading",
      "title": "ಶ್ರೀ ಭಾಷ್ಯಂ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅಖಿಲಭುವನ ಜನ್ಮಸ್ತೇಮ ಭಂಗಾದಿ ಲೀಲೇ।",
        "ವಿನತ ವಿವಿಧ ಭೂತವ್ರಾತ ರಕ್ಷೆಕ ದೀಕ್ಷೆ ",
        "ಶ್ರುತಿ ಶಿರಸಿ ವಿದೀಪ್ತೇ ಬ್ರಹ್ಮಣಿ ಶ್ರೀನಿವಾಸೇ",
        "ಭವತು ಮಮ ಪರಸ್ಮಿನ್ ಶೇಮುಷೀ ಭಕ್ತಿರೂಪಾ"
      ]
    },
    {
      "type": "subheading",
      "title": "ಶರಣಾಗತಿ ಗದ್ಯಂ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ಭಗವನ್ನಾರಾಯಣಾಭಿ ಮತಾನುರೂಪ ಸ್ವರೂಪ ರೂಪ",
        "ಗುಣವಿಭವೈಶ್ವರ್ಯ ಶೀಲಾದ್ಯನವದಿಕ",
        "ಅತಿಶಯಾ ಸಂಖ್ಯೇಯ ಕಲ್ಯಾಣ ಗುಣಗಣಾಂ", 
        "ಪದ್ಮವನಾಲಯಾಂ ಭಗವತೀಂ ಶ್ರಿಯಂ ದೇವೀಂ",
        "ನಿತ್ಯಾನುಪಾಯಿನೀಂ ನಿರವದ್ಯಾಂ ದೇವದೇವ ದಿವ್ಯಮಹಿಷೀಂ",
        "ಅಖಿಲ ಜಗನ್ಮಾತರಂ ಅಸ್ಮನ್ಮಾತರಂ",
        "ಅಶರಣ್ಯ ಶರಣ್ಯಾಂ ಅನನ್ಯ ಶರಣಃ ಶರಣಂ ಅಹಂ ಪ್ರಪದ್ಯೇ"
      ]
    },
    {
      "type": "subheading",
      "title": "ರಹಸ್ಯತ್ರಯ ಸಾರಂ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ಮಣಿವರ ಇವಶೌರೇಃ ನಿತ್ಯಹೃದ್ಯೋಪಿ ಜೀವಃ।",
        "ಕಲುಷಮತಿರವಿಂದನ್ ಕಿಂಕರತ್ವಾಧಿರಾಜ್ಯಂ",
        "ವಿಧಿಪರಿಣತಿ ಭೇದಾತ್ ವೀಕ್ಷಿತಸ್ಥೇನಕಾಲೇ ",
        "ಗುರುಪರಿಷದುಪಜ್ಞಂ ಪ್ರಾಪ್ಯ ಗೋಪಾಯತಿಸ್ತ್ವಂನ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನಿರ್ವಿಷ್ಟಂ ಯತಿ ಸಾರ್ವಭೌಮವ ಚಸಾಮಾವೃತ್ತಿಭಿರ್ಯೌವನಂ",
        "ನಿರ್ಧೂತೇತರ ಪಾರತಂತ್ರ್ಯ ನಿರಯಾ ನೀತಾಸ್ಸುಖಂ ವಾಸರಾಃ ।",
        "ಅಂಗೀಕೃತ್ಯ ಸತಾಂ ಪ್ರಸತ್ತಿಮಸತಾಂ ಗರ್ವೋಪಿ ನಿರ್ವಾಪಿತಃ",
        "ಶೇಷಾಯುಷ್ಯಪಿ ಶೇಷದಂಪತಿದಯಾ ದೀಕ್ಷಾಮುದೀಕ್ಷಾಮಹೇ",
        "ರಹಸ್ಯತ್ರಯಸಾರೋಯಂ ವೇಂಕಟೇಶ ವಿಪಶ್ಚಿತಾ",
        "ಶರಣ್ಯದಂಪತಿವಿದಾಂ ಸಂಮತಸ್ಸಮಗೃಹ್ಯತ"
      ]
    },
    {
      "type": "subheading",
      "title": "ಶ್ರೀ ಗುಣರತ್ನಕೋಶಂ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ಉಲ್ಲಾಸಪಲ್ಲವಿತ ಪಾಲಿತ ಸಪ್ತಲೋಕೀ।",
        "ನಿರ್ವಾಹಕೋರಕಿತನೇಮ ಕಟಾಕ್ಷಲೀಲಾಂ",
        "ಶ್ರೀರಂಗಹರ್ಮ್ಯತಲ ಮಂಗಳದೀಪ ರೇಖಾಂ",
        "ಶ್ರೀರಂಗರಾಜ ಮಹಿಷೀಂ ಶ್ರಿಯಮಾಶ್ರಯಾಮಃ"
      ]
    },
    {
      "type": "subheading",
      "title": "ಯತಿರಾಜಸಪ್ತತಿ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ಉಪವೀತಿನಂ ಊರ್ಧ್ವಪುಂಡ್ರವಂತಂ",
        "ತ್ರಿಜಗತ್ ಪುಣ್ಯಫಲಂ ತ್ರಿದಂಡಹಸ್ತಂ",
        "ಶರಣಾಗತಸಾರ್ಥ ವಾಹಮೀಡೇ",
        "ಶಿಖಯಾ ಶೇಖರಿಣಂ ಪತಿಂ ಯತೀನಾಂ"
     ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಗಾಥಾತಾಥಾಗತಾನಾಂ ಗಲತಿ ಗಮನಿಕಾ ಕಾಪಿಲೀ ಕ್ವಾಪಿ ಲೀನಾ",
        "ಕ್ಷೀಣಾಕಾಣಾದವಾಣೀ ದ್ರುಹಿಣಹರಗಿರಸೌರಭಂ ನಾರಭಂತೇ",
        "ಕ್ಷಾಮಾಕೌಮಾರಿಲೋಕ್ತಿರ್ಜಗತಿ ಗುರುಮತಂ ಗೌರವಾದ್ದೂರವಾಂತಂ",
        "ಕಾಶಂಕಾ ಶಂಕರಾದೇರ್ಭಜತಿ ಯತಿಪತ್ ಭದ್ರವೇದೀಂ ತ್ರಿವೇದೀಂ"
      ]
    },
    {
      "type": "subheading",
      "title": "ಯತಿರಾಜವಿಂಶತಿ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರೀ ಮಾಧವಾಂಘಿ ಜಲಜದ್ವಯ ನಿತ್ಯ ಸೇವಾ",
        "ಪ್ರೇಮಾ ವಿಲಾಸಯ ಪರಾಂಕುಶ ಪಾದ ಪದ್ಮಂ",
        "ಕಾಮಾದಿ ದೋಷ ಹರ ಆಶ್ರಿತ ಪದಾರಿತಾನಾಂ",
        "ರಾಮಾನುಜಂ ಯತಿಪತಿಂ ಪ್ರಣಮಾಮಿ ಮೂರ್ಧಾ"
      ]
    },
    {
      "type": "subheading",
      "title": "ಪಾದುಕಾಸಹಸ್ರಂ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕನಕ ರುಚಿರಾ ಕಾವ್ಯಾಖ್ಯಾತಾ ಶನೈಶ್ಚರಣೋಚಿತಾ",
        "ಶ್ರಿತಗುರುಬುಧಾ ಭಾಸ್ವದ್ರೂಪಾ ದ್ವಿಜಾಧಿಪ ಸೇವಿತಾ",
        "ವಿಹಿತ ವಿಭವಾನಿತ್ಯಂ ವಿಷ್ಟೋ ಪದೇಮಣಿಪಾದುಕೇ",
        "ತ್ವಮಸಿಮಹತಿ: ವಿಶ್ವೇಷಾಂ ನಃ ಶುಭಾಗ್ರಹಮಣ್ಣಲೀ ।।"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಜಯತಿ ಯತಿರಾಜಸೂಕ್ತಿಃ ಜಯತಿ ಮುಕುಂದಸ್ಯ ಪಾದುಕಾ ಯುಗಳೀ ।",
        "ತದುಭಯ ದನಾಸ್ತ್ರಿವೇದೀಂ ಅವಂಧ್ಯಯಂತೋ ಜಯಂತಿ ಭುವಿ ಸಂತಃ ||",
        "ಸಂತಃ ಶ್ರೀರಂಗ ಪೃಥ್ವೀಶ ಚರಣತ್ರಾಣ ಶೇಖರಾಃ",
        "ಜಯಂತಿ ಭುವನತ್ರಾಣ ಪದಪಂಕಜ ರೇಣವಃ ।।"
      ]
    }
      ]
    }
    