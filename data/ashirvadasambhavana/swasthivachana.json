    {
      "type": "subheading",
      "title": "ದಂಪತ್ಯೋಃ"
    },
    {
      "type": "paragraph",
      "lines": [
        "ಓಂ, ಸ್ವಾಮಿನಃ, ಸ್ವಸ್ತಿಮಂತ್ರಾರ್ಥಾಸ್ಸತ್ಯಾಸ್ಸಫಲಾಸ್ಸನ್ವಿತಿ",
        "ಭವಂತೋ ಮಹಾಂತೋಽನುಗೃಹ್ಣಂತು ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅನಯೋರ್ದಂಪತ್ಯೋರ್ವೇದೋಕ್ತಂ ದೀರ್ಘಮಾಯುಷ್ಯಂ",
        "ಭೂಯಾದಿತಿ ತತ್ರ ಭವಂತೋ ಮಹಾಂತೋಽನುಗೃಹ್ಣಂತು ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅದ್ಯಾನುಷ್ಠಿತೇ ...... ಶುಭಕರ್ಮಣಿ ಮಂತ್ರಲೋಪೇ, ತಂತ್ರಲೋಪೇ,",
        "ದ್ರವ್ಯಲೋಪೇ, ಶ್ರದ್ಧಾಲೋಪೇ ಸಂಭವತ್ಯಪಿ ಸರ್ವಂ ಸಾಂಗಂ,",
        "ಯಥಾಶಾಸ್ತ್ರಾನುಷ್ಠಿತಂ ಭೂಯಾದಿತಿ ಭವಂತೋ ಮಹಾಂತೋಽನುಗೃಹ್ಣಂತು ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಇಮೌ ದಂಪತೀ, ವಂದಾರುಕ-ಬೃಂದಾರುಕ-ಬೃಂದಾಗ್ರಗಣ್ಯ-",
        "ಕೋಟೀರಕೋಟಿ-ತಟಘಟಿತ-ಚಟುಲ-ಮಣಿಪಟಲ-",
        "ವಿಸೃಮರ-ಸುರುಚಿರ-ಮರೀಚಿವೀಚೀ-ಪರಿಚುಂಬಿತ-ಚರಣಾಂಬುಜಸ್ಯ,",
        "ಕಲಶಾಂಬುಧಿರಾಜಸ್ಯ ಕನ್ಯಾಸ್ತನಸ್ತಬಕ-ವಾಸ್ತವ್ಯ-ನಿಸ್ತುಲ-",
        "ಕಸ್ತೂರಿಕಾಮೋದ-ಪ್ರಶಸ್ತ-ಸೌವಸ್ತಿಕ-ಕೌಸ್ತುಭಾಭರಣಸ್ಯ,",
        "ರಮಾಲೋಚನ-ಚಕೋರಶೀತಕಿರಣಸ್ಯ,",
        "ಕ್ಷಮಾಚಿತ್ತ ಸರೋಜಷಟ್ಟರಣಸ್ಯ,",
        "ನೀಲಾವಿಲಾಸ-ವಿಹಾರ-ಚರಣಸ್ಯ, ಶರಣಾಗತ-ಭರಣಾಯತ್ತ-ಕರುಣಸ್ಯ,",
        "ಫಣಾಧರಧುರೀಣ-ಧರಣೀಧರಾಭರಣಸ್ಯ,ಜ್ಞಾನ-ಶಕ್ತಿ-ಬಲೈಃ ಐಶ್ವರ್ಯಾತ್‌",
        "ಅನಂತ-ಕಲ್ಯಾಣಗುಣಗಣ-ವಿಲಾಸ-ನಿವಾಸಸ್ಯ,",
        "ಭಗವತಃ ಶ್ರೀ ಶ್ರೀನಿವಾಸಸ್ಯ ಪರದೈವತಸ್ಯಾನುಗ್ರಹೇಣ,"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶಚೀಪುರಂದರಾವಿವ ಅತಿಮಾತ್ರ-ಸೌಭಾಗ್ಯ-ಧುರಂಧರೌ, ",
        "ಸರಸ್ವತೀಚತುರಾನನಾವಿವ ಸಕಲಕಲಾ-ಚತುರಾನನೌ, ",
        "ಜಾನಕೀರಘುಪುಂಗವಾವಿವ ಜಗದಾನಂದನೌ,",
        "ರೋಹಿಣೀಚಂದ್ರಮಸಾವಿವ ಪರಸ್ಪರಪ್ರೇಮಸಾಂದ್ರಮನಸೌ,",
        "ಅರುಂಧತೀವಸಿಷ್ಠಾವಿವ ಸದಾಚಾರಸಂಪನ್ನೌ, ",
        "ರತಿಕುಸುಮಬಾಣಾವಿವ ಅನ್ನೋನ್ಯಾನುರೂಪರೂಪೌ,",
        "ರುಕ್ಕಿಣೀವಾಸುದೇವಾವಿವ ಪ್ರವರ್ಧಮಾನ ಪುತ್ರಪೌತ್ರಾದಿ ಸಂತಾನಪ್ರಭಾವೌ,",
        "ಭೂಯಾಸ್ತಾಮಿತಿ ಭವಂತೋ ಮಹಾಂತೋಽನುಗೃಹ್ಣಂತು ॥",
        "ಏನಯೋರ್ದಂಪತ್ಯೋರ್ಗೃಹೇ ಧನಕನಕವಸ್ತುವಾಹನಸಮೃದ್ಧಿಃ",
        "ಭೂಯಾದಿತಿ ಭವಂತೋ ಮಹಾಂತೋಽನುಗೃಹ್ಣಂತು ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಏನಯೋರ್ದಂಪತ್ಯೋರ್ಗೃಹೇ ಮಹಾಲಕ್ಷ್ಮ್ಯಾಃ ಸ್ಥೈರ್ಯಂ ಸಾನ್ನಿಧ್ಯಂ ಸವಿಲಾಸಂ",
        "ಭೂಯಾದಿತಿ ಭವಂತೋ ಮಹಾಂತೋಽನುಗೃಹ್ಣಂತು ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅಸ್ಮಿನ್ ದೇಶೇ ಕ್ಷಾಮಕ್ಷೋಭನಿವೃತ್ತಿಃ",
        "ಭೂಯಾದಿತಿ ಭವಂತೋ ಮಹಾಂತೋಽನುಗೃಹ್ಣಂತು ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅಸ್ಮಿನ್ ದೇಶೇ ಸದ್ಯಃ ಸುವೃಷ್ಟ್ಯಾ ಸರ್ವೇ ನದನದೀತಟಾಕಾಃ ಸಂಪೂರ್ಣಾಃ",
        "ಭೂಯಾಸುರಿತಿ ಭವಂತೋ ಮಹಾಂತೋಽನುಗೃಹ್ಣಂತು॥"
      ]
    },
     {
      "type": "paragraph",
      "lines": [
        "ಸರ್ವೇ ಜನಾಃ ಸುಖಿನಃ ಸಂತ್ವಿತಿ ಭವಂತೋ ಮಹಾಂತೋಽನುಗೃಹ್ಣಂತು ॥",
        "ಸಮಸ್ತ ಸನ್ಮಂಗಳಾನಿ ಭವಂತ್ವಿತಿ ಭವಂತೋ ಮಹಾಂತೋಽನುಗೃಹ್ಣಂತು ॥",
        "ಸತ್ಯಾಃ ಏತಾಃ ಆಶಿಷಸ್ಸಂತ್ವಿತಿ ಭವಂತೋ ಮಹಾಂತೋಽನುಗೃಹ್ಣಂತು ॥"
      ]
    },
