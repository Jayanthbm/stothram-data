{
  "title": "ದಶಶಿರ ದೈತ್ಯನು ಲೋಕವಬಾಧಿಸೆ",
  "content": [
    {
      "type": "paragraph",
      "lines": [
        "ದಶಶಿರ ದೈತ್ಯನು ಲೋಕವ ಬಾಧಿಸೆ ।",
        "ದಶರಥಗುದಿಸಿದ ಶ್ರೀರಾಮ||",
        "ವಸುಧೆಯ ಭಾರವನಿಳುಹಲು ಜನಿಸಿದ |",
        "ವಸುದೇವ ನಂದನ ಶ್ರೀಕೃಷ್ಣ || 1 ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರೀಮಲ್ಲಕ್ಷ್ಮಣ ಭರತಶತೃಘ್ನ ರಿಂ ।",
        "ಪ್ರೇಮದಿ ಮೆರೆದನು ಶ್ರೀರಾಮ ||",
        "ಭಾಮಿನಿ ರೋಹಿಣಿಯೊಳಗುದಿಸಿದ ಬಲ |",
        "ರಾಮನೆನಿಸಿದನು ಶ್ರೀ ಕೃಷ್ಣ || 2 ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವಿಶ್ವಾಮಿತ್ರನ ಯಜ್ಞವ ರಕ್ಷಿಸೆ ।",
        "ವಿಶ್ವವನೈದಿದ ಶ್ರೀರಾಮ ||",
        "ವಿಶ್ವಸ್ವರೂಪನು ಗೋಕುಲದೊಳಗೇ ।",
        "ವಿಶ್ವರೊಳಾಡಿದ ಶ್ರೀಕೃಷ್ಣ || 3 ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಮುನಿಯೊಡನೈದುತ ವನದೊಳು ತಾಟಕೆ |",
        "ಧನುಜೆಯ ಕೊಂದನು ಶ್ರೀರಾಮ ।",
        "ಜನನಿಯ ತೆರದಿಂಸ್ತನಗಳ ಕೊಡೆ ಪೂ |",
        "ತನಿಯನು ಕೊಂದನು ಶ್ರೀಕೃಷ್ಣ || 4 ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಮುನಿಯುಪದೇಶದ ಮಂತ್ರದಿ ಕಲಿತನು |",
        "ಧನುರಾಗಮವನು ಶ್ರೀರಾಮ ||",
        "ಮನೆಹೊರಭಾಗದಿ ಬೀದಿಯೊಳೆಲ್ಲಾ|",
        "ಕುಣಿಕುಣಿದಾಡಿದ ಶ್ರೀಕೃಷ್ಣ || 5 ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಜ್ಞಾನೋಪದೇಶದ ಮಂತ್ರವ ಕಲಿತನು |",
        "ಜ್ಞಾನಸ್ವರೂಪನು ಶ್ರೀರಾಮ ||",
        "ಮಾನಿನಿಗೊಲ್ಲರ ಮನೆಯೊಳು ಬೆಣ್ಣೆಯ ।",
        "ತಾನಲಿದುಂಡನು ಶ್ರೀಕೃಷ್ಣ || 6 ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಋಷಿಗಳ ಯಜ್ಞವ ಕೆಡಿಸಲು ಬಂದಾ|",
        "ಅಸುರರ ಕೊಂದನು ಶ್ರೀರಾಮ ||",
        "ಎಸೆಯುವ ಗೋಕುಲದೊಳು ನರನಟನೆಯ|",
        "ಶಿಶುವೆನೆ ತೋರಿದ ಶ್ರೀಕೃಷ್ಣ || 7 ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕಲ್ಲಾಗಿದ್ದ ಅಹಲೈಗೆ ರೂಪವ|",
        "ನಲ್ಲಿಯೆ ಕೊಟ್ಟನು ಶ್ರೀರಾಮ ||",
        "ಗೊಲ್ಲತಿಯರ ಕೂಡಾಡುತ ಗೊಲ್ಲರ||",
        "ಪಲ್ಲಿಯೊಳಿದ್ದನು ಶ್ರೀಕೃಷ್ಣ || 8 ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಧರಣೆಜೆ ಸೀತೆಗೆ ಸ್ವಯಂವರವಾಗಲು|",
        "ಭರದೊಳು ಬಂದನು ಶ್ರೀರಾಮ ||",
        "ದುರಳ ಕಾಳಿಂಗನ ಹಡೆಯನು ಮೆಟ್ಟುತ ||",
        "ಪರಿಪರಿದಾಡಿದ ಶ್ರೀಕೃಷ್ಣ || 9 ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪರುಶುಗ್ರಾಹಿಯು ಬಿಲ್ಲನು ತೋರಲು|",
        "ಭರದಿಂದೆಳೆದನು ಶ್ರೀರಾಮ ||",
        "ತರಳನನೊರಳಿಗೆ ಕಟ್ಟಲು ಮತ್ತಿಯ ||",
        "ಮರಗಳ ಮುರಿದನು ಶ್ರೀಕೃಷ್ಣ || 10 ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ತಂದೆಯ ವರವನು ಸಲಿಸಲು ಬಂದನು|",
        "ಕುಂದದೆ ಕಾಡಿಗೆ ಶ್ರೀರಾಮ ||",
        "ಬೃಂದೆಯ ವನದೊಳು ಕೊಳಲೂದುತೆಗೋ|",
        "ಬೃಂದವ ಕಾಯ್ದನು ಶ್ರೀಕೃಷ್ಣ || 11 ||"
      ]
     },
     {
       "type": "paragraph",
       "lines": [
         "ಧರಣೆಜೆ ಲಕ್ಷ್ಮಣರೊಡನಾ ಮುನಿಗಳ|",
         "ಪೊರೆಯೊಳಗಾಡಿದ ಶ್ರೀರಾಮ ||",
         "ತರುಣಿಯರೊಂದಿಗೆ ಜಲಕ್ರೀಡೆಯಾಡುತ|",
         "ಸರಸದೊಳಗಾಡಿದ ಶ್ರೀಕೃಷ್ಣ || 12 ||"
       ]
     },
     {
       "type": "paragraph",
       "lines": [
         "ಗುಹನನು ಮನ್ನಿಸಿ ಭರತಗೆ ರಾಜ್ಯದ|",
         "ಮಹವನು ಇತ್ತನು ಶ್ರೀರಾಮ ||",
         "ಮಹಿತರಕ್ರೂರೋದ್ಭವ ಮುಖ್ಯರ|",
         "ವಿಹಿತದಿ ಪೊರೆದನು ಶ್ರೀಕೃಷ್ಣ|| 13 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ಚಿತ್ರಕೂಟದಿ ಭರತಗೆ ಪಾದುಕೆ|",
         "ಯಿತ್ತೊರೆಯೊಲಿಸಿದ ಶ್ರೀರಾಮ ||",
         "ಚಿತ್ರಯುದ್ಧದಿ ಸ್ಯಮಂತಕದೊಡನೆ|",
         "ಸತ್ಯೆಯ ತಂದನು ಶ್ರೀ ಕೃಷ್ಣ|| 14 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ದಂಡಕವನದಲಿ ಮಾಯಾಮೃಗವನು|",
         "ಕಂಡದರುಹಿದ ಶ್ರೀರಾಮ ||",
         "ದಂಡಗಳಿಂದಲೆ ಹಿಂಡಿನ ದೈತ್ಯರ|",
         "ದಿಂಡುರುಳಿಸಿದನು ಶ್ರೀಕೃಷ್ಣ|| 15 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ಮೃಗವನು ಬಯಸಲು ಸೀತೆಯು ಬಾಣವ|",
         "ತೆಗೆಯುತಲೋಡಿದ ಶ್ರೀರಾಮ ||",
         "ಬಗೆಬಗೆಲೀಲೆಗಳಿಂದಲಿ ಗೋಪಿಯ|",
         "ರೊಗುಮಿಗೆಯಾದನು ಶ್ರೀಕೃಷ್ಣ|| 16 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ರಾವಣ ಸೀತೆಯ ಕದ್ದು ದ ಕಂಡಾ|",
         "ಭಾವೆಗೆ ಮರುಗಿದ ಶ್ರೀರಾಮ ||",
         "ದೇವರವಿಭು ಮಳೆಗರೆಯಲು ನೆಗಹಿದ|",
         "ಗೋವರ್ಧನವನು ಶ್ರೀಕೃಷ್ಣ|| 17 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ಪಥದಲಿ ಬಿದ್ದ ಜಟಾಯುಗೆ ಮುಕ್ತಿಯ|",
         "ಪಥಕಾಣಿಸಿದನು ಶ್ರೀರಾಮ ||",
         "ಹಿತದಿಂ ದೌಪದಿಗಭಯವನಿತ್ತು|",
         "ವ್ರತಪಾಲಿಸಿದನು ಶ್ರೀಕೃಷ್ಣ|| 18 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ವಾಲಿಯ ರಣದಲಿ ಕೊಂದು ಸುಗ್ರೀವನ|",
         "ಪಾಲಿಸಿಕೊಂಡನು ಶ್ರೀರಾಮ ||",
         "ಲೋಲೇಕ್ಷಣೆಯರ ಸಹಿತಲೆ ನಾನಾ|",
         "ಲೀಲೆಗಳಾಡಿದ ಶ್ರೀಕೃಷ್ಣ|| 19 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ವನಚರರೊಡನಾ ವನಿತೆಯನರಸಲು|",
         "ಹನುಮನ ಕಳುಹಿದ ಶ್ರೀರಾಮ ||",
         "ದನುಜರ ಧೇನುಕ ಬಕರನು ಕೊಲ್ಲುತೆ|",
         "ತೊನೆದುರುಳಿಸಿದನು ಶ್ರೀಕೃಷ್ಣ|| 20 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ಮುದ್ರಿಕೆಯುಂಗುರ ಜಾನಕಿಗಿತ್ತನು|",
         "ಸುದ್ದಿಯ ಜೊತೆಯಲಿ ಶ್ರೀರಾಮ ||",
         "ಹೊದ್ದಿದ ಗೋಪಿಗೆ ಲೀಲೆಯ ತೋರಿದ|",
         "ಮುದ್ದಿನ ಚಿನ್ಮಯ ಶ್ರೀಕೃಷ್ಣ|| 21 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ಚೂಡಾಮಣಿಯನು ಭಾಮೆಯ ಹನುಮನು|",
         "ನೀಡಲು ಮರುಗಿದ ಶ್ರೀರಾಮ ||",
         "ಕೇಡಿಗದನುಜನ ಕೊಲ್ಲಲು ಹಾವಿನ |",
         "ದಾಡೆಯ ಹೊಕ್ಕನು ಶ್ರೀಕೃಷ್ಣ|| 22 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ಸೀತೆಯು ಲಂಕೆಯೊಳಗಿರುವುದ ಕೇಳಿಯೆ|",
         "ಕಾತುರನಾದನು ಶ್ರೀರಾಮ ||",
         "ಜಾತವ ಭೂಮಿಯ ಭಾರವನಿಳುಹಲು |",
         "ಭೂತವ ಕೊಂದನು ಶ್ರೀಕೃಷ್ಣ|| 23 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ರಾವಣ ದೂರಲು ಬಂದ ವಿಭೀಷಣ|",
         "ದೇವನಸಲುಹಿದ ಶ್ರೀರಾಮ ||",
         "ಮಾವನ ನೋಡಲು ಮಧುರೆಗೆ ಬಂದ ಬಲ |",
         "ದೇವನು ಸಹಿತಲೆ ಶ್ರೀಕೃಷ್ಣ || 24 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ವಾನರರಿಂದಲೆ ದೈತ್ಯರ ಕೊಲ್ಲಿಸೆ|",
         "ದಾನವಗೊಲಿದನು ಶ್ರೀರಾಮ ||",
         "ಹೀನನ ರಜಕನಕೊಲ್ಲುತ ಮಲ್ಲರ |",
         "ಆನಕ ಬಡಿದನು ಶ್ರೀಕೃಷ್ಣ || 25 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ಅಂಬುಧಿ ಬಂಧನ ಮಾಡಿದನಾಗಲೆ|",
         "ಅಂಬುಜಲೋಚನ ಶ್ರೀರಾಮ ||",
         "ಕುಂಭಿನಿಯೊಳಗಾ ಗಂಧದ ಕುಪ್ಪೆಯ |",
         "ದೊಂಬಿಯ ತಿದ್ದಿದ ಶ್ರೀಕೃಷ್ಣ || 26 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ಕುಂಭಶ್ರವಣ ಪ್ರಮುಖರ ಮಡುಹಿದ|",
         "ಅಂಬುಜಲೋಚನ ಶ್ರೀರಾಮ ||",
         "ನಂಬಿದ ಭಕ್ತರ ಪಾಲಿಸೆ ಕಂಸನ |",
         "ಕುಂಭಿನಿಗೌಕಿದ ಶ್ರೀಕೃಷ್ಣ || 27 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ರಾವಣನನ್ನೇ ಕೊಂದಾ ತಮ್ಮಗೆ |",
         "ಭೂವನು ಕೊಟ್ಟನು ಶ್ರೀರಾಮ ||",
         "ಮಾವನ ಕೊಲ್ಲತ್ತಯ್ಯಗೆ ಪಟ್ಟವ |",
         "ಭಾವದಿ ಕಟ್ಟಿದ ಶ್ರೀಕೃಷ್ಣ || 28 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ಮಡದಿಯನಗ್ನಿಗೆ ಪುಗಿಸಿಯೆ ಭರತಗೆ |",
         "ನುಡಿದುದ ಸಲಿಸಿದ ಶ್ರೀರಾಮ ||",
         "ಮಡುಹಿಯೆ ಮುರನನು ನಿರ್ಜರತರುವನು |",
         "ಪೊಡವಿಯಲಿರಿಸಿದ ಶ್ರೀಕೃಷ್ಣ || 29 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ಧರೆಯೊಳಗುತ್ತಮವಾದಾ ಕೋಸಲ |",
         "ಪುರವನ್ನಾಳಿದ ಶ್ರೀರಾಮ ||",
         "ಧರುಣಿಪ ಬಾಣಾಸುರನಾ ಕರಗಳ |",
         "ಮುರಿಯಿಸಿ ಮೆರೆದನು ಶ್ರೀಕೃಷ್ಣ || 30 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ಯುದ್ಧದಿ ಲವಕುಶರಂಬಿನ ಗಾಯಕೆ  |",
         "ಬಿದ್ದನು ಧರಣೆಗೆ ಶ್ರೀರಾಮ ||",
         "ಸದ್ದಿ ತದೊಳು ಯಾದವಕುಲವನು ತಾ  |",
         "ನುದ್ದರ ಗೈದನು ಶ್ರೀಕೃಷ್ಣ || 31 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ಶ್ರೀಮದಯೋಧ್ಯಾ ಪುರದಲಿ ನೆಲೆಸಿದ  |",
         "ಭಾಮೆಯ ಸಹಿತಲಿ ಶ್ರೀರಾಮ ||",
         "ಪ್ರೇಮದಿ ನೆಲೆಸಿದ ದ್ವಾರಾವತಿಯಲಿ  |",
         "ಕಾಮಿನಿಸಹಿತಲಿ ಶ್ರೀಕೃಷ್ಣ || 32 ||"
       ]
      },
      {
       "type": "paragraph",
       "lines": [
         "ರಾಮಾಯಣದಾಕಥೆಯನು ಪೇಳಲು|",
         "ಪ್ರೇಮದಿ ಸಲಹುವ ಶ್ರೀರಾಮ ||",
         "ಪ್ರೇಮದೊಳಾ ಭಾಗವತವ ಪರಿಸಲು  |",
         "ಕಾಮಿತವೀವನು ಶ್ರೀಕೃಷ್ಣ || 33 ||"
       ]
        }
      ]
    }
