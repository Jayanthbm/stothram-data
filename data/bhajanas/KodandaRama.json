    "en": {
      "title": "Kodanda Rama",
      "fonts": {
        "subheading": "NotoSans",
        "paragraph": "NotoSans"
      },
      "content": [
        {
          "type": "paragraph",
          "lines": [
            "Kodanda Rama Kodanda Rama",
            "Kodanda Rama Paahi Kodanda Rama"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Shrikara Traahi Bhaskara Dehi Lokesha Traahi Sadguna Paahi"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Neerolutoori Paataala Seri Vedava Torida Matsyavatari"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Nagesha Brahma Prarthipe Nimma",
            "Aadi Nee Koorma Paalisu Namma"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Kalirupa Taali Dhanujana Seeli",
            "Dhareya Mahaa Li Parama Krupaali"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Narahari Roopa Taali Prataapa",
            "Torida Bhoopa Prauda Kalaapa"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Baliyanu Metti Hrudayava Kutti Paataala Kattida Vaamana Jetti"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Dasharatha Bhaala Dashashira Lola Dashamukha Kaala Dashaanu Koola"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Daathrija Vamsha Maadida Dvamsa Munikoola Hamsa Satya Prashamsa"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Gokula Rakshaa Sujana Samrakshaa Pootani Shikshaa Kanjaadalaakshaa"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Bettale Nindu Bauddhane Endu Bhaktiyolindu Prarthipevindu"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Kalkyavatara Kalimana Doora Dhurita Prahaara Sujannoddara"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Saagara Vaasa Naagamukesha",
            "Nudisida Bhaashaa Bhajana Vishesha"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Sujanaru Koodi Bhajaneya Maadi Bhajisutalaadi Jagava Kondaadi"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Mangala Rama Mangala Bheema Mangala Dhaama Jagadanees Seema"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Jaya Raghuveera Jagadadi Shoora Bhaya Nivaara Bhakta Mandaara"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Dasharatha Putra Dhanya Charitra",
            "Pashumati Mitra Punya Sugaatra"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Rajeeva Netra Ramaneeya Gaatra Seeta Kalaatra Sindhu Pavitra"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Bhavya Vilaasa Bhakta Sankaasha Bhava Bhaya Shoora Bhaktaadi Vaasa"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Chinmaya Rama Chidrupadaana",
            "Akhanda Rama Aananda Rama"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Shree Rama Rama Gopala Rama Shreelola Rama Janaki Rama"
          ]
        }
      ]
    }
  }
}
