{
  "title": "ಕೋದಂಡರಾಮ",
  "fonts": {
    "subheading": "NotoSans",
    "paragraph": "NudiParijathaBold"
  },
  "content": [
    {
      "type": "paragraph",
      "lines": [
        "ಕೋದಂಡರಾಮ ಕೋದಂಡರಾಮ",
        "ಕೋದಂಡರಾಮ ಪಾಹಿ ಕೋದಂಡರಾಮ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರಿಕರತ್ರಾಹಿ ಭಾಸ್ಕರದೇಹಿ ಲೋಕೇಶತ್ರಾಹಿ ಸದ್ಗುಣ ಪಾಹಿ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನೀರೊಳುತೂರಿ ಪಾತಳಸೇರಿ ವೇದವತೋರಿದ ಮತ್ಸ್ಯಾವತಾರಿ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನಾಗೇಶ ಭ್ರಮ್ಹಾ ಪ್ರಾರ್ಥಿಪೆ ನಿಮ್ಮ",
        "ಆದಿ ನೀ ಕೂರ್ಮ ಪಾಲಿಸುನಮ್ಮ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕಲಿರುಪ ತಾಳಿ ಧನುಜನ ಸೀಳಿ",
        "ಧರೆಯ ಮಹಾಳಿಪರಮ ಕೃಪಾಳಿ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನರಹರಿ ರೂಪ ತಾಳಿ ಪ್ರತಾಪ",
        "ತೋರಿದ ಭೂಪ ಪ್ರೌಡಕಲಾಪ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಬಲಿಯನುಮೆಟ್ಟಿ ಹೃದಯವ ಕುಟ್ಟಿ ಪಾತಾಳ ಕಟ್ಟಿದ ವಾಮನ ಜೆಟ್ಟಿ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ದಶರಥ ಭಾಲ ದಶಶಿರ ಲೋಲ ದಶಮುಖಕಾಲ ದಶಾನು ಕೂಲ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ದಾತ್ರಿಜ ವಂಶ ಮಾಡಿದ ದ್ವಂಸ ಮುನಿಕುಲ ಹಂಸ ಸತ್ಯ ಪ್ರಶಂಸ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಗೋಕುಲ ರಕ್ಷಾ ಸುಜನ ಸಂರಕ್ಷಾ ಪೂತನಿ ಶಿಕ್ಷಾ ಕಂಜಾದಳಾಕ್ಷ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಬೆತ್ತಲೆ ನಿಂದು ಭೌದ್ದನೆ ಎಂದು ಭಕ್ತಿಯೊಳಿಂದು ಪ್ರಾರ್ತಿಪೆವಿಂದು"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕಲ್ಕ್ಯವತಾರ ಕಲಿಮನ ದೂರ ಧುರಿತಪ್ರಹಾರ ಸುಜನ್ನೋದ್ಧಾರ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸಾಗರ ವಾಸ ನಾಗಮುಕೇಶ",
        "ನುಡಿಸಿದ ಭಾಷಾ ಭಜನ ವಿಶೇಷ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸುಜನರು ಕೂಡಿ ಭಜನೆಯ ಮಾಡಿ ಭಜಿಸುತಲಾಡಿ ಜಗವಕೊಂಡಾಡಿ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಮಂಗಳಾರಾಮ ಮಂಗಳಭೀಮ ಮಂಗಳಧಾಮ ಜಗದನೀಸ್ಸೀಮ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಜಯರಘುವೀರ ಜಗಧದಿ ಶೂರ ಭಯನಿವಹಾರ ಭಕ್ತಮಂದಾರ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ದಶರಥ ಪುತ್ರ ಧನ್ಯಚರಿತ್ರ",
        "ಪಶುಮತಿ ಮಿತ್ರ ಪುಣ್ಯ ಸುಗಾತ್ರ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ರಾಜೀವ ನೇತ್ರ ರಮಣೀಯ ಘಾತ್ರ ಸೀತಾ ಕಲಾತ್ರ ಸಿಂಧೂಪವಿತ್ರ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಭವ್ಯ ವಿಲಾಸ ಭಕ್ತ ಸಂಕಾಶ ಭವ ಭಯ ಶೂರ ಭಕ್ತಾದಿ ವಾಸ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಚಿನ್ಮಯ ರಾಮ ಚಿದ್ರುಪರಾಮ",
        "ಅಖಂಡ ರಾಮ ಆನಂದರಾಮ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರೀ ರಾಮ ರಾಮ ಗೋಪಾಲ ರಾಮ ಶ್ರೀಲೋಲ ರಾಮ ಜಾನಕಿ ರಾಮ"
      ]
    }
  ],
