{
  "title": "ರಾಧೇಶ್ಯಾಮ್‌ ರಾಧೇಶ್ಯಾಮ್",
  "content": [
    {
      "type": "paragraph",
      "lines": [
        "ರಾಧೇಶ್ಯಾಮ್‌ ರಾಧೇಶ್ಯಾಮ್‌ ರಾಧಾ ಮಾಧವ ಮೇಘ ಶ್ಯಾಮ್‌ ಆದಿನಾರಾಯಣ ರಾಧೇ ಶ್ಯಾಮ್"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಆದಿನಾರಾಯಣ ರಾಧೇ ಶ್ಯಾಮ್  ಅನಾದಿ ಪುರುಷ ಮೇಘ ಶ್ಯಾಮ್‌ ||",
        "ವಾಸುದೇವಹರಿ ರಾಧೇ ಶ್ಯಾಮ್  ವಾಸುಕಿ ಶಯನನೆ ಮೇಘ ಶ್ಯಾಮ್ || ೧ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ದೇವಕಿ ತನಯ ರಾಧೇ ಶ್ಯಾಮ್‌ ದೇವ ದೇವ ಹರಿ ಮೇಘ ಶ್ಯಾಮ್ ||",
        "ಭಾವಜನಯ್ಯನೆ ರಾಧೇ ಶ್ಯಾಮ್‌ ಗೋವಳ ಪ್ರಿಯಹರಿ ಮೇಘ ಶ್ಯಾಮ್‌ || ೨ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪೂತನಿ ಮರ್ಧನ ರಾಧೇ ಶ್ಯಾಮ್‌ ಶಕಟ ಸಂಹಾರ ಮೇಘ ಶ್ಯಾಮ್‌ ಮಾತುಳ ಧ್ವಂಸಿ ರಾಧೇ ಶ್ಯಾಮ್ |",
        "ಅನಾಥ ರಕ್ಷಕ ಮೇಘ ಶ್ಯಾಮ್ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಮುರಳಿ ಮನೋಹರ ರಾಧೇ ಶ್ಯಾಮ್‌ | ನರಕಾಂತಕ ಹರಿ ಮೇಘ ಶ್ಯಾಮ್ |",
        "ಕರುಣಾಕರ ಹರಿ ರಾಧೇ ಶ್ಯಾಮ್‌ | ಕರುಣಿಸಿ ಪೊರೆ ಹರಿ ಮೇಘ ಶ್ಯಾಮ್ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪಾಂಡವ ಪ್ರಾಣನೆ ರಾಧೇ ಶ್ಯಾಮ್‌ |",
        "ಪಾಂಡವ ತ್ರಾಣನೆ ಮೇಘ ಶ್ಯಾಮ್ |",
        "ಪಾಂಡವ ರಕ್ಷಕ ರಾಧೇ ಶ್ಯಾಮ್‌ |",
        "ಕೌರವ ಶಿಕ್ಷಕ ಮೇಘ ಶ್ಯಾಮ್ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಗೋಪೀಜಾತನೆ ರಾಧೇ ಶ್ಯಾಮ್‌ |",
        "ಗೋಪೀನಾಥನೆ ಮೇಘ ಶ್ಯಾಮ್ |",
        "ಗೋಪಿಕ ವಲ್ಲಭ ರಾಧೇ ಶ್ಯಾಮ್ |",
        "ಗೋಕುಲ ನಂದನ ಮೇಘ ಶ್ಯಾಮ್‌"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರೀಪರಮೇಶನೆ ರಾಧೇ ಶ್ಯಾಮ್‌ |",
        "ಕೇಶವ ಅಚ್ಯುತ ಮೇಘ ಶ್ಯಾಮ್ |",
        "ದೋಷ ಕ್ಷಮಿಸಿ ಪೊರೆ ರಾಧೇ ಶ್ಯಾಮ್ |",
        "ದಾಸ ಕೇಶವನುತ ಮೇಘ ಶ್ಯಾಮ್ ||"
      ]
    }
  ],
  "translations": {
    "kn": {
      "title": "ರಾಧೇಶ್ಯಾಮ್‌ ರಾಧೇಶ್ಯಾಮ್",
      "content": [
        {
          "type": "paragraph",
          "lines": [
            "ರಾಧೇಶ್ಯಾಮ್‌ ರಾಧೇಶ್ಯಾಮ್‌ ರಾಧಾ ಮಾಧವ ಮೇಘ ಶ್ಯಾಮ್‌ ಆದಿನಾರಾಯಣ ರಾಧೇ ಶ್ಯಾಮ್"
          ]
        }
      ]
    },
    "en": {
      "title": "Radhe Shyam Radhe Shyam",
      "content": [
        {
          "type": "paragraph",
          "lines": [
            "Radhe Shyam Radhe Shyam Radha Madhava Megha Shyam Adi Narayana Radhe Shyam"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Adi Narayana Radhe Shyam Anadi Purusha Megha Shyam |",
            "Vasudeva Hari Radhe Shyam Vasuki Shayanane Megha Shyam || 1 ||"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Devaki Tanaya Radhe Shyam Deva Deva Hari Megha Shyam |",
            "Bhava Janayyane Radhe Shyam Govala Priya Hari Megha Shyam || 2 ||"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Putani Mardhana Radhe Shyam Shakata Samhara Megha Shyam |",
            "Anatha Rakshaka Megha Shyam ||"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Murali Manohara Radhe Shyam Narakantaka Hari Megha Shyam |",
            "Karunakara Hari Radhe Shyam Karunisi Pore Hari Megha Shyam ||"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Pandava Pranane Radhe Shyam |",
            "Pandava Tranane Megha Shyam |",
            "Pandava Rakshaka Radhe Shyam |",
            "Kaurava Shikshaka Megha Shyam ||"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Gopi Jatane Radhe Shyam |",
            "Gopinathane Megha Shyam |",
            "Gopika Vallabha Radhe Shyam |",
            "Gokula Nandana Megha Shyam"
          ]
        },
        {
          "type": "paragraph",
          "lines": [
            "Sri Parameshane Radhe Shyam |",
            "Keshava Achyuta Megha Shyam |",
            "Dosha Kshamisi Pore Radhe Shyam |",
            "Dasa Keshavanuta Megha Shyam ||"
          ]
        }
      ]
    }
  }
}
