{
  "title": "ದಶಾವತಾರ ಸ್ತೋತ್ರಂ",
  "fonts": {
    "subheading": "NotoSans",
    "paragraph": "NudiParijathaBold"
  },
  "content": [
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರೀಮಾನ್ವೇಂಕಟನಾಥಾರ್ಯಃ ಕವಿತಾರ್ಕಿಕಕೇಸರೀ |",
        "ವೇದಾಂತಾಚಾರ್ಯವರ್ಯೋ ಮೇ ಸನ್ನಿಧತ್ತಾಂ ಸದಾ ಹೃದಿ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ದೇವೋನಃ ಶುಭಮಾತನೋತು ದಶಧಾ ನಿರ್ವರ್ತಯನ್ ಭೂಮಿಕಾಂ",
        "ರಂಗೇ ಧಾಮನಿ ಲಬ್ಧ ನಿರ್ಭರ ರಸೈಃರಧ್ಯಕ್ಷಿತೋ ಭಾವುಕೈಃ |",
        "ಯದ್ಭಾವೇಷು ಪೃಥಗ್ವಿಧೇಷ್ವನುಗುಣಾನ್ ಭಾವಾನ್ಸ್ವಯಂ ಬಿಭ್ರತೀ",
        "ಯದ್ಧರ್ಮೈರಿಹ ಧರ್ಮಿಣೀ ವಿಹರತೇ ನಾನಾಕೃತಿರ್ನಾಯಿಕಾ ||1||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನಿರ್ಮಗ್ನಃ ಶ್ರುತಿಜಾಲ ಮಾರ್ಗಣದಶಾ ದತ್ತಕ್ಷಣೈರ್ವೀಕ್ಷಣೈಃ",
        "ಅಂತಸ್ತನ್ವದಿವಾರವಿಂದ ಗಹನಾ ನ್ಯೌದನ್ವತೀನಾಮಪಾಮ್ |",
        "ನಿಷ್ಪ್ರತ್ಯೂಹ ತರಂಗರಿಂಗಣ ಮಿಥಃ ಪ್ರತ್ಯೂಢಪಾಥಶ್ಛಟಾ-",
        "ಡೋಲಾರೋಹ ಸದೋಹಳಂ ಭಗವತೋ ಮಾತ್ಸ್ಯಂ ವಪುಃ ಪಾತು ನಃ ||2||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅವ್ಯಾಸುರ್ಭುವನತ್ರಯೀಂ ಅನಿಭೃತಂ ಕಂಡೂಯನೈರದ್ರಿಣಾ",
        "ನಿದ್ರಾಣಸ್ಯ ಪರಸ್ಯ ಕೂರ್ಮವಪುಷೋ ನಿಃಶ್ವಾಸವಾತೋರ್ಮಯಃ |",
        "ಯದ್ವಿಕ್ಷೇಪಣ ಸಂಸ್ಕೃತೋದಧಿಪಯಃ ಪ್ರೇಂಖೋಳ ಪರ್ಯಂಕಿಕಾ",
        "ನಿತ್ಯಾರೋಹಣ ನಿರ್ವೃತೋ ವಿಹರತೇ ದೇವಃ ಸಹೈವ ಶ್ರಿಯಾ ||3||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಗೋಪಾಯೇದನಿಶಂ ಜಗಂತಿ ಕುಹನಾಪೋತ್ರೀ ಪವಿತ್ರೀಕೃತ-",
        "ಬ್ರಹ್ಮಾಂಡಃ ಪ್ರಳಯೋರ್ಮಿ ಘೋಷ ಗುರುಭಿರ್ಘೋಣಾರವೈರ್ಘುರ್ಘುರೈಃ |",
        "ಯದ್ದಂಷ್ಟ್ರಾಂಕುರ ಕೋಟಿಗಾಢಘಟನಾ ನಿಷ್ಕಂಪ ನಿತ್ಯಸ್ಥಿತಿಃ",
        "ಬ್ರಹ್ಮಸ್ತಂಬಮಸೌದಸೌ ಭಗವತೀ ಮುಸ್ತೇವ ವಿಶ್ವಂಭರಾ ||4||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪ್ರತ್ಯಾದಿಷ್ಟ ಪುರಾತನ ಪ್ರಹರಣ ಗ್ರಾಮಃ ಕ್ಷಣಂ ಪಾಣಿಜೈಃ",
        "ಅವ್ಯಾತ್ತ್ರೀಣಿ ಜಗಂತ್ಯಕುಂಠ ಮಹಿಮಾ ವೈಕುಂಠಕಂಠೀರವಃ |",
        "ಯತ್ಪ್ರಾದುರ್ಭವನಾದವಂಧ್ಯಜಠರಾ ಯಾದೃಚ್ಛಿಕಾದ್ವೇಧಸಾಂ",
        "ಯಾ ಕಾಚಿತ್ಸಹಸಾ ಮಹಾಸುರ ಗೃಹಸ್ಥೂಣಾ ಪಿತಾಮಹ್ಯಭೂತ್ ||5||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವ್ರೀಡಾವಿದ್ಧವದಾನ್ಯ ದಾನವಯಶೋ ನಾಸೀರಧಾಟೀಭಟಃ",
        "ತ್ರೈಯಕ್ಷಂ ಮುಕುಟಂ ಪುನನ್ನವತು ನಸ್ತ್ರೈವಿಕ್ರಮೋ ವಿಕ್ರಮಃ |",
        "ಯತ್ಪ್ರಸ್ತಾವ ಸಮುಚ್ಛ್ರಿತ ಧ್ವಜಪಟೀ ವೃತ್ತಾಂತಸಿದ್ಧಾಂತಿಭಿಃ",
        "ಸ್ರೋತೋಭಿಃ ಸುರಸಿಂಧುರಷ್ಟಸು ದಿಶಾ ಸೌಧೇಷು ದೋಧೂಯತೇ ||6||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕ್ರೋಧಾಗ್ನಿಂ ಜಮದಗ್ನಿ ಪೀಡನಭವಂ ಸಂತರ್ಪಯಿಷ್ಯನ್ ಕ್ರಮಾತ್",
        "ಅಕ್ಷತ್ರಾಮಿಹ ಸಂತ ತಕ್ಷಯ ಇಮಾಂ ತ್ರಿಸ್ಸಪ್ತ ಕೃತ್ವಃ ಕ್ಷಿತಿಮ್ |",
        "ದತ್ತ್ವಾ ಕರ್ಮಣಿ ದಕ್ಷಿಣಾಂ ಕ್ವಚನತಾಮಾಸ್ಕಂದ್ಯ ಸಿಂಧುಂ ವಸನ್",
        "ಅಬ್ರಹ್ಮಣ್ಯಮಪಾಕರೋತು ಭಗವಾನ್ ಆಬ್ರಹ್ಮ ಕೀಟಂ ಮುನಿಃ ||7||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪಾರಾವಾರ ಪಯೋ ವಿಶೋಷಣ ಕಲಾ ಪಾರೀಣ ಕಾಲಾನಲ",
        "ಜ್ವಾಲಾಜಾಲ ವಿಹಾರ ಹಾರಿ ವಿಶಿಖ ವ್ಯಾಪಾರ ಘೋರಕ್ರಮಃ |",
        "ಸರ್ವಾವಸ್ಥ ಸಕೃತ್ ಪ್ರಪನ್ನ ಜನತಾ ಸಂರಕ್ಷಣೈಕವ್ರತೀ",
        "ಧರ್ಮೋ ವಿಗ್ರಹವಾನಧರ್ಮ ವಿರತಿಂ ಧನ್ವೀ ಸ ತನ್ವೀತು ನಃ ||8||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಫಕ್ಕತ್ಕೌರವ ಪಟ್ಟಣ ಪ್ರಭೃತಯಃ ಪ್ರಾಸ್ತಪ್ರಲಂಬಾದಯಃ",
        "ತಾಲಾಂಕಸ್ಯ ತಥಾವಿಧಾ ವಿಹೃತಯಸ್ತನ್ವಂತು ಭದ್ರಾಣಿ ನಃ |",
        "ಕ್ಷೀರಂ ಶರ್ಕರಯೇವ ಯಾಭಿರ ಪೃಥಗ್ಭೂತಾಃ ಪ್ರಭೂತೈರ್ಗುಣೈಃ",
        "ಆಕೌಮಾರಕಮಸ್ವ ದಂತ ಜಗತಃ ಕೃಷ್ಣಸ್ಯ ತಾಃ ಕೇಲಯಃ ||9||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನಾಥಾಯೈವ ನಮಃ ಪದಂ ಭವತು ನಶ್ಚಿತ್ರೈಶ್ಚರಿತ್ರ ಕ್ರಮೈಃ",
        "ಭೂಯೋ ಭಿರ್ಭುವನಾನ್ಯಮೂನಿ ಕುಹನಾ ಗೋಪಾಯ ಗೋಪಾಯತೇ |",
        "ಕಾಳಿಂದೀರಸಿಕಾಯ ಕಾಳಿಯಫಣಿ ಸ್ಫಾರಸ್ಫಟಾ ವಾಟಿಕಾ",
        "ರಂಗೋತ್ಸಂಗ ವಿಶಂಕ ಚಂಕ್ರ ಮಧುರಾ ಪರ್ಯಾಯ ಚರ್ಯಾಯ ತೇ ||10||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಭಾವಿನ್ಯಾ ದಶಯಾ ಭವನ್ನಿಹ ಭವ ಧ್ವಂಸಾಯ ನಃ ಕಲ್ಪತಾಂ",
        "ಕಲ್ಕೀ ವಿಷ್ಣು ಯಶಸ್ಸುತಃ ಕಲಿಕಥಾ ಕಾಲುಷ್ಯ ಕೂಲಂಕಷಃ |",
        "ನಿಃಶೇಷ ಕ್ಷತಕಂಟಕೇ ಕ್ಷಿತಿತಲೇ ಧಾರಾ ಜಲೌಘೈರ್ಧ್ರುವಂ",
        "ಧರ್ಮಂ ಕಾರ್ತಯುಗಂ ಪ್ರರೋಹಯತಿ ಯನ್ನಿಸ್ತ್ರಿಂಶಧಾರಾಧರಃ ||11||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "**ಇಚ್ಛಾಮೀನ ವಿಹಾರಕಚ್ಛಪ ಮಹಾಪೋತ್ರಿನ್ ಯದೃಚ್ಛಾಹರೇ",
        "ರಕ್ಷಾವಾಮನ ರೋಷರಾಮ ಕರುಣಾ ಕಾಕುತ್ಸ್ಥ ಹೇಲಾಹಲಿನ್ |",
        "ಕ್ರೀಡಾವಲ್ಲವ ಕಲ್ಕ ವಾಹನ ದಶಾ ಕಲ್ಕಿನ್ನಿತಿ ಪ್ರತ್ಯಹಂ",
        "ಜಲ್ಪಂತಃ ಪುರುಷಾಃ ಪುನಂತಿ ಭುವನಂ ಪುಣ್ಯೌಘ ಪಣ್ಯಾಪಣಾಃ ||12||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "**ವಿದ್ಯೋದನ್ವತಿ ವೇಂಕಟೇಶ್ವರಕವೌ ಜಾತಂ ಜಗನ್ಮಂಗಳಂ",
        "ದೇವೇಶಸ್ಯ ದಶಾವತಾರ ವಿಷಯಂ ಸ್ತೋತ್ರಂ ವಿವಕ್ಷೇತ ಯಃ |",
        "ವಕ್ತ್ರೇ ತಸ್ಯ ಸರಸ್ವತೀ ಬಹುಮುಖೀ ಭಕ್ತಿಃ ಪರಾ ಮಾನಸೇ",
        "ಶುದ್ಧಿಃ ಕಾಽಪಿ ತನೌ ದಿಶಾಸು ದಶಸು ಖ್ಯಾತಿಃ ಶುಭಾ ಜೃಂಭತೇ ||13||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕವಿತಾರ್ಕಿಕಸಿಂಹಾಯ ಕಲ್ಯಾಣಗುಣಶಾಲಿನೇ |",
        "ಶ್ರೀಮತೇ ವೇಂಕಟೇಶಾಯ ವೇದಾಂತಗುರವೇ ನಮಃ"
      ]
    }
  ]
} 
