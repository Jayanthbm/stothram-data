{
  "title": "ಶ್ರೀದೇಶಿಕಮಂಗಳಂ",
  "content": [
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರೀಕುಮಾರವರದಾಯೇರ್ಣ ಅನುಗೃಹೀತಂ",

        "ಶ್ರೀಮಾನ್ ವೇಂಕಟನಾಥಾರ್ಯಃ ಕವಿತಾರ್ಕಿಕಕೇಸರಿ",
        "ವೇದಾಂತಾಚಾರ್ಯವರ್ಯೋ ಮೇ ಸನ್ನಿಧತ್ತಾಂ ಸದಾ ಹೃದಿ ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರೀಮಲ್ಲಕ್ಷ್ಮಣ ಯೋಗೀಂದ್ರ ಸಿದ್ಧಾಂತ ವಿಜಯಧ್ವಜಂ",
        "ವಿಶ್ವಾಮಿತ್ರ ಕುಲೋದ್ಭೂತಂ ವರದಾರ್ಯಮಹಂ ಭಜೇ ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸರ್ವತಂತ್ರ ಸ್ವತಂತ್ರಾಯ ಸಿಂಹಾಯ ಕವಿ ವಾದಿನಾಂ",
        "ವೇದಾಂತಾಚಾರ್ಯ ವರ್ಯಾಯ ವೇಂಕಟೇಶಾಯ ಮಂಗಳಂ ॥ 1 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನಭಸ್ಯಮಾಸಿ ಶ್ರೋಣಾಯಾಂ ಅವತೀರ್ಣಾಯ ಸೂರಯೇ",
        "ವಿಶ್ವಾಮಿತ್ರಾನ್ವಯಾಯಾಸ್ತು ವೇಂಕಟೇಶಾಯ ಮಂಗಳಂ ॥ 2 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪಿತಾ ಯಸ್ಯಾನಂತಸೂರಿಃ ಪುಂಡರೀಕಾಕ್ಷ ಯಜ್ವನಃ",
        "ಪೌತ್ರೋ ಯಸ್ತನಯಸ್ತೋತಾ ರಂಬಾಯಾಸ್ತಸ್ಯ ಮಂಗಳಂ ॥ 3 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವೇಂಕಟೇಶಾವತಾರೋಽಯಂ ತದ್ಘಂಟಾಂ ಶೋಽಥವಾ ಭವೇತ್",
        "ಯತೀಂದ್ರಾಂ ಶೋಽಥವೇತ್ಯೇವಂ ವಿತರ್ಕ್ಯಾಯಾಸ್ತು ಮಂಗಳಂ ॥ 4 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರೀಭಾಷ್ಯಕಾರಃ ಪಂಥಾನಂ ಆತ್ಮನಾ ದರ್ಶಿತಂ ಪುನಃ",
        "ಉದ್ಧರ್ತುಮಾಗತೋ ನೂನ ಮಿತ್ಯುಕ್ತ್ಯಾಯಾಸ್ತು ಮಂಗಳಂ ॥ 5 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಯೋ ಬಾಲ್ಯೇ ವರದಾಯರ್ಸ್ಯ ಪ್ರಾಚಾರ್ಯಸ್ಯ ಪರಾಂ ದಯಾಂ",
        "ಅವಾಪ್ಯ ವೃದ್ಧಿಂ ಗಮಿತಃ ತಸ್ಮೈ ಯೋಗ್ಯಾಯ ಮಂಗಳಂ ॥ 6 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ರಾಮಾನುಜಾರ್ಯದಾತ್ರೇಯಾತ್ ಮಾತುಲಾತ್ ಸಕಲಾಃ ಕಲಾಃ",
        "ಅವಾಪ ವಿಂಶತ್ಯಬ್ದೇ ಯಃ ತಸ್ಮೈ ಪ್ರಾಜ್ಞಾಯ ಮಂಗಳಂ ॥ 7 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರುತಪ್ರಕಾಶಿಕಾ ಭೂಮೌ ಯೇನಾದೌ ಪರಿರಕ್ಷಿತಾ",
        "ಪ್ರವೃತ್ತಾ ಚ ಪಾತ್ರೇಷು ತಸ್ಮೈ ಶ್ರೇಷ್ಠಾಯ ಮಂಗಳಂ ॥ 8 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸಾಂಸ್ಕೃತೀಭಿರ್ದ್ರಾವಿಡೀಭಿಃ ಬಹ್ವೀಭಿಃ ಕೃತಿಭಿರ್ಜನಾನ್",
        "ಯಸ್ಸಮುಜ್ಜೀವಯಾಮಾಸ ತಸ್ಮೈ ಸೇವ್ಯಾಯ ಮಂಗಳಂ ॥ 9 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಯಃ ಖ್ಯಾತಿ ಲಾಭ ಪೂಜಾಸು ವಿಮುಖೋ ವೈಷ್ಣವೇ ಜನೇ",
        "ಕ್ರಯಣೀಯದಶಾಂ ಪ್ರಾಪ್ತಃ ತಸ್ಮೈ ಭವ್ಯಾಯ ಮಂಗಳಂ ॥ 10 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಯಸ್ಮಾದೇವ ಮಯಾ ಸರ್ವಂ ಶಾಸ್ತ್ರಮಗ್ರಾಹಿ ನಾನ್ಯತಃ",
        "ತಸ್ಮೈ ವೇಂಕಟನಾಥಾಯ ಮಮ ನಾಥಾಯ ಮಂಗಳಂ ॥ 11 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "*ಪಿತ್ರೇ ಬ್ರಹ್ಮೋಪದೇಷ್ಟ್ರೇ ಮೇ ಗುರವೇ ದೈವತಾಯ ಚ",
        "ಪ್ರಾಪ್ಯಾಯ ಪ್ರಾಪಕಾಯಾಸ್ತು ವೇಂಕಟೇಶಾಯ ಮಂಗಳಂ ॥ 12 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಯಃ ಕೃತಂ ವರದಾಯೇರ್ಣ ವೇದಾಂತಾಚಾರ್ಯ ಮಂಗಳಂ",
        "ಆಶಾಸ್ತೇಽನುದಿನಂ ಸೋಽಪಿ ಭವೇನ್ಮಂಗಳಭಾಜನಂ ॥ 13 ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಭಾದ್ರಪದ ಮಾಸಗತ ವಿಷ್ಣು ವಿಮಲಕ್ಷೇತ್ರೇ",
        "ವೇಂಕಟ ಮಹೀಧ್ರ ಪತಿತೀರ್ಥ ದಿನಭೂತೇ",
        "ಪ್ರಾದುರ್ಭವಜ್ಜಗತಿ ದೈತ್ಯರಿಪು ಘಂಟಾ",
        "ಹಂತ ಕವಿತಾರ್ಕಿಕ ಮೃಗೇಂದ್ರ ಗುರು ಮೂರ್ತ್ಯಾ ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಘಂಟಾ ವೃಷಾ ಚಲಪತೇ ಕಮಲಾಸನೇನ",
        "ಪೂಜಾರ್ತಮಾತ್ಮ ಹೃದಯೇನ ಸಮರ್ಪಿತೈವ |",
        "ತಂತ್ರಾಂತರಸ್ಥಿತ ಪಿಶಾಚ ಪಲಾಯನಾರ್ಥಂ",
        "ಆವಿರ್ಭಭೂವ ವರವೇದ ಶಿಖಾರ್ಯ ಮೂರ್ತ್ಯಾ ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸಶಂಖ ಚಕ್ರ ಲಾಂಛನಃ ಸದೂರ್ಧ್ವ ಪುಂಡ್ರ ಮಂಡಿತಃ",
        "ಸಕಂಠ ಲಗ್ನ ಸತ್ತುಲಸ್ಯ ನರ್ಘ ಪದ್ಮ ಮಾಲಿಕಃ",
        "ಸಿತಾಂತರೀಯ ಸೂತ್ತರೀಯ ಯಜ್ಞ ಸೂತ್ರ ಶೋಭಿತಃ",
        "ಮಮಾವಿರಸ್ತು ಮಾನಸೇ ಗುರುಃ ಸ ವೇಂಕಟೇಶ್ವರಃ ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅನಂತ ಸೂರಿ ಸೂನವೇಭಿನಂದ್ಯ ಮಾನ ವೈಭವಾತ್",
        "ದಿಗಂತ ವಾದಿ ಹಂಸಜೈತ್ರ ಕಾಲಮೇಘ ದೇಶಿಕಾತ್",
        "ಉಪಾತ್ತ ಸರ್ವ ಶಾಸನಾಯ ಹಂತ ವರ್ಷ ವಿಂಶತೌ",
        "ಪುನಃ ಪುನರ್ನಮಸ್ಕ್ರಿಯಾಸ್ತು ವೇಂಕಟೇಶ ಸೂರಯೇ ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕವಿತಾರ್ಕಿಕ ಕಲಭವ್ರಜ ಕಬಲೀ ಕೃತಿ ಸಿಂಹಂ",
        "ಕಮಲಾ ಪತಿ ಕರುಣಾ ರಸ ಪರಿವರ್ಧಿತ ಬೋಧಂ",
        "ಯತಿ ನಾಯಕ ಪದ ಪಂಕಜ ಯುಗಲೀ ಪರ ತಂತ್ರಂ",
        "ಭಜ ಮಾನಸ ಬುಧ ವೇಂಕಟ ಪತಿ ದೇಶಿಕ ಮನಿಶಂ ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕಲಯೇ ಸತತಂ ಕರುಣಾ ಜಲಧಿಂ",
        "ಕರುಣಾ ವಿಷಯಂ ಕಮಲಾಧಿಪತೇಃ",
        "ಕಲಿವೈರಿ ಶಠಾರಿ ವಚೋ ರಸಿಕಂ",
        "ಕವಿತಾರ್ಕಿಕ ಕೇಸರಿ ಸೂರಿಗುರುಂ ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಗುರೌ ವಾದಿ ಹಂಸಾಂ ಬುದಾ ಚಾರ್ಯ ಶಿಷ್ಯೇ",
        "ಜನಾ ಭಕ್ತಿಹೀನಾ ಯತೀಂದ್ರಾ ಪ್ರಿಯಾಃ ಸ್ಯುಃ",
        "ಯತೀಂದ್ರಾ ಪ್ರಿಯಾ ವಿಷ್ಣು ಕಾರುಣ್ಯ ದೂರಾಃ",
        "ಕುತೋ ಮುಕ್ತಿವಾರ್ತಾ ಹಿ ತಾದೃಗ್ವಿಧಾನಾಂ ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವೇದೇ ಸಂಜಾತಖೇದೇ ಮುನಿಜನವಚನೇ ಪ್ರಾಪ್ತ ನಿತ್ಯಾವಮಾನೆ",
        "ಸಂಕೀರ್ಣೇ ಸರ್ವವರ್ಣೇ ಸತಿ ತದನುಗುಣೇ ನಿಷ್ಪ್ರಮಾಣೇ ಪುರಾಣೇ",
        "ಮಾಯಾವಾದೇ ಸಮೋದೇ ಕಲಿಕಲುಷವಶಾತ್ ಶೂನ್ಯವಾದೇಽವಿವಾದೇ",
        "ಧರ್ಮತ್ರಾಣಾಯ ಯೋಽಭೂತ್ ಸಃ ಜಯತಿ ಭಗವಾನ್",
        "ವಿಷ್ಣು ಘಂಟಾವತಾರಃ ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕವಿತಾರ್ಕಿಕಸಿಂಹಾಯ ಕಲ್ಯಾಣಗುಣಶಾಲಿನೇ",
        "ಶ್ರೀಮತೇ ವೇಂಕಟೇಶಾಯ ವೇದಾಂತಗುರವೇ ನಮಃ ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವಾದಿದ್ವಿಪ ಶಿರೋಭಂಗ ಪಂಚಾನನ ಪರಾಕ್ರಮಃ",
        "ಶ್ರೀಮಾನ್ ವೇಂಕಟನಾಥಾರ್ಯಃ ಚಿರಂ ವಿಜಯತಾಂ ಭುವಿ ॥"
      ]
    }
  ]
}
