{
  "title": "ಶ್ರೀ ಸುದರ್ಶನಾಷ್ಟಕಂ",
  "fonts": {
    "subheading": "NotoSans",
    "paragraph": "NudiParijathaBold"
  },
  "content": [
    {
      "type": "paragraph",
      "lines": [
        "ಸಹಸ್ರಾರಂ ರಕ್ತವರ್ಣಂ ರಾಜಸಂಖ್ಯಾ ಭುಜಾನ್ವಿತಂ |",
        "ಜ್ವಾಲಾಕೇಶ೦ ತ್ರಿನಯನಂ ಪಟ್ಕೋಣೋಪರಿ ಸಂಸ್ಥಿತಂ",
        "ಕೋಟಿ ಸೂರ್ಯಪ್ರತೀಕಾಶಂ ಶಂಖಚಕ್ರಾದಿ ಧಾರಣಂ |",
        "ವಿಷ್ಣು ಹಸ್ತಾಯುಧಂ ದೇವಂ ಸುದರ್ಶನಮಹಂ ಭಜೇ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರೀಮಾನ್ವೇಂಕಟನಾಥಾರ್ಯಃ ಕವಿತಾರ್ಕಿಕ ಕೇಸರೀ |",
        "ವೇದಾಂತಾಚಾರ್ಯವರ್ಯೋ ಮೇ ಸನ್ನಿಧತ್ತಾಂ ಸದಾ ಹೃದಿ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪ್ರತಿಭಟಶ್ರೇಣಿಭೀಷಣ ವರಗುಣಸ್ತೋಮಭೂಷಣ",
        "ಜನಿಭಯಸ್ಥಾನತಾರಣ ಜಗದವಸ್ಥಾನಕಾರಣ |",
        "ನಿಖಿಲದುಷ್ಕರ್ಮಕರ್ಶನ ನಿಗಮಸದ್ಧರ್ಮದರ್ಶನ",
        "ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ||೧||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶುಭಜಗದ್ರೂಪ ಮಂಡನ ಸುರಜನತ್ರಾಸ ಖಂಡನ",
        "ಶತಮಖಬ್ರಹ್ಮ ವಂದಿತ ಶತಪಥಬ್ರಹ್ಮ ನಂದಿತ |",
        "ಪ್ರಥಿತ ವಿದ್ವತ್ಸಪಕ್ಷಿತ ಭಜದಹಿರ್ಬುಧ್ನ್ಯ ಲಕ್ಷಿತ",
        "ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ||೨||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸ್ಫುಟತಟಿಜ್ಜಾಲ ಪಿಂಜರ ಪೃಥುತರಜ್ವಾಲ ಪಂಜರ",
        "ಪರಿಗತಪ್ರಜ್ಞ ವಿಗ್ರಹ ಪಟುತರ ಪ್ರಜ್ಞ ದುರ್ಗ್ರಹ |",
        "ಪ್ರಹರಣಗ್ರಾಮ ಮಂಡಿತ ಪರಿಜನತ್ರಾಣ ಪಂಡಿತ",
        "ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ||೩||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನಿಜಪದಪ್ರೀತ ಸದ್ಗಣ ನಿರುಪಧಿಸ್ಫೀತ ಷಡ್ಗುಣ",
        "ನಿಗಮನಿರ್ವ್ಯೂಢ ವೈಭವ ನಿಜಪರವ್ಯೂಹ ವೈಭವ |",
        "ಹರಿಹಯದ್ವೇಷಿ ದಾರಣ ಹರಪುರಪ್ಲೋಷ ಕಾರಣ",
        "ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ||೪||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ದನುಜವಿಸ್ತಾರ ಕರ್ತನ ಜನಿತಮಿಸ್ರಾ ವಿಕರ್ತನ",
        "ದನುಜ ವಿದ್ಯಾನಿಕರ್ತನ ಭಜದ ವಿದ್ಯಾ ನಿವರ್ತನ |",
        "ಅಮರದೃಷ್ಟಸ್ವ ವಿಕ್ರಮ ಸಮರ ಜುಷ್ಟಭ್ರಮಿಕ್ರಮ",
        "ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ||೫||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪ್ರತಿಮುಖಾಲೀಢ ಬಂಧುರ ಪೃಥುಮಹಾಹೇತಿ ದಂತುರ",
        "ವಿಕಟಮಾಯಾ ಬಹಿಷ್ಕೃತ ವಿವಿಧಮಾಲಾ ಪರಿಷ್ಕೃತ |",
        "ಸ್ಥಿರಮಹಾಯಂತ್ರ ತಂತ್ರಿತ ದೃಢದಯಾತಂತ್ರ ಯಂತ್ರಿತ",
        "ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ||೬||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಮಹಿತಸಂಪತ್ಸದಕ್ಷರ ವಿಹಿತಸಂಪತ್ಷಡಕ್ಷರ",
        "ಷಡರಚಕ್ರಪ್ರತಿಷ್ಠಿತ ಸಕಲತತ್ತ್ವ ಪ್ರತಿಷ್ಠಿತ |",
        "ವಿವಿಧಸಂಕಲ್ಪ ಕಲ್ಪಕ ವಿಬುಧ ಸಂಕಲ್ಪಕಲ್ಪಕ",
        "ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ||೭||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಭುವನನೇತ್ರ ತ್ರಯೀಮಯ ಸವನತೇಜಸ್ತ್ರಯೀಮಯ",
        "ನಿರವಧಿಸ್ವಾದು ಚಿನ್ಮಯ ನಿಖಿಲಶಕ್ತೇ ಜಗನ್ಮಯ |",
        "ಅಮಿತವಿಶ್ವಕ್ರಿಯಾಮಯ ಶಮಿತವಿಷ್ವಗ್ಭಯಾಮಯ",
        "ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ಜಯ ಜಯ ಶ್ರೀಸುದರ್ಶನ ||೮||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ದ್ವಿಚತುಷ್ಕಮಿದಂ ಪ್ರಭೂತಸಾರಂ",
        "ಪಠತಾಂ ವೇಂಕಟನಾಯಕಪ್ರಣೀತಮ್ |",
        "ವಿಷಮೇಽಪಿ ಮನೋರಥಃ ಪ್ರಧಾವನ್",
        "ನ ವಿಹನ್ಯೇತ ರಥಾಂಗಧುರ್ಯಗುಪ್ತಃ ||೯||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕವಿತಾರ್ಕಿಕಸಿಂಹಾಯ ಕಲ್ಯಾಣಗುಣಶಾಲಿನೇ|",
        "ಶ್ರೀಮತೇ ವೇಂಕಟೇಶಾಯ ವೇದಾಂತಗುರವೇ ನಮಃ"
      ]
    }
  ]
}
