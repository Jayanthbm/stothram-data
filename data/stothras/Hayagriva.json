{
  "title": "ಶ್ರೀ ಹಯಗ್ರೀವ ಸ್ತೋತ್ರಂ",
  "content": [
    {
      "type": "paragraph",
      "lines": [
        "ಜ್ಞಾನಾನಂದಮಯಂ ದೇವಂ ನಿರ್ಮಲ ಸ್ಫಟಿಕಾಕೃತಿಂ",
        "ಆಧಾರಂ ಸರ್ವವಿದ್ಯಾನಾಂ ಹಯಗ್ರೀವಮುಪಾಸ್ಮಹೇ ||1||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸ್ವತಸ್ಸಿದ್ಧಂ ಶುದ್ಧಸ್ಫಟಿಕಮಣಿ ಭೂsಭೃತ್ಪ್ರತಿಭಟಂ",
        "ಸುಧಾಸಧ್ರೀಚೀಭಿಃ ಧ್ಯುತಿಭಿರವದಾತ ತ್ರಿಭುವನಂ",
        "ಅನಂತೈಸ್ತ್ರಯ್ಯಂತೈಃ ಅನುವಿಹಿತ ಹೇಷಾಹಲಹಲಂ",
        "ಹತಾಶೇಷಾವದ್ಯಂ ಹಯವದನ ಮೀಡೇಮಹಿಮಹಃ ||2||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸಮಾಹಾರಸ್ಸಾಮ್ನಾಂ ಪ್ರತಿಪದಮೃಚಾಂ ಧಾಮ ಯಜುಷಾಂ",
        "ಲಯಃ ಪ್ರತ್ಯೂಹಾನಾಂ ಲಹರಿವಿತತಿರ್ಬೋಧ ಜಲಧೇಃ",
        "ಕಥಾದರ್ಪಕ್ಷುಭ್ಯತ್ಕಥಕಕುಲ ಕೋಲಾಹಲಭವಂ",
        "ಹರತ್ವಂತರ್ಧ್ವಾಂತಂ ಹಯವದನ ಹೇಷಾಹಲಹಲಃ ||3||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪ್ರಾಚೀ ಸಂಧ್ಯಾ ಕಾಚಿದಂತರ್ನಿಶಾಯಾಃ",
        "ಪ್ರಜ್ಞಾದೃಷ್ಟೇ ರಂಜನಶ್ರೀರಪೂರ್ವಾ",
        "ವಕ್ತ್ರೀ ವೇದಾನ್ ಭಾತು ಮೇ ವಾಜಿವಕ್ತ್ರಾ",
        "ವಾಗೀಶಾಖ್ಯಾ ವಾಸುದೇವಸ್ಯ ಮೂರ್ತಿಃ ||4||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವಿಶುದ್ಧ ವಿಜ್ಞಾನ ಘನಸ್ವರೂಪಂ",
        "ವಿಜ್ಞಾನ ವಿಶ್ರಾಣನ ಬದ್ಧದೀಕ್ಷಂ",
        "ದಯಾನಿಧಿಂ ದೇಹಭೃತಾಂ ಶರಣ್ಯಂ",
        "ದೇವಂ ಹಯಗ್ರೀವಮಹಂ ಪ್ರಪದ್ಯೇ ||5||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅಪೌರುಷೇಯೈರಪಿ ವಾಕ್‌ ಪ್ರಪಂಚೈಃ",
        "ಅದ್ಯಾಪಿ ತೇ ಭೂತಿಮದೃಷ್ಟ ಪಾರಾಂ",
        "ಸ್ತುವನ್ನಹಂ ಮುಗ್ಧ ಇತಿ ತ್ವಯೈವ",
        "ಕಾರುಣ್ಯತೋ ನಾಥ ಕಟಾಕ್ಷಣೀಯಃ ||6||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ದಾಕ್ಷಿಣ್ಯರಮ್ಯಾ ಗಿರಿಶಸ್ಯ ಮೂರ್ತಿಃ-",
        "ದೇವೀ ಸರೋಜಾಸನ ಧರ್ಮಪತ್ನೀ",
        "ವ್ಯಾಸಾದಯೋಽಪಿ ವ್ಯಪದೇಶ್ಯ ವಾಚಃ",
        "ಸ್ಫುರಂತಿ ಸರ್ವೇ ತವ ಶಕ್ತಿಲೇಶೈಃ ||7||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಮಂದೋಽಭವಿಷ್ಯನ್ನಿಯತಂ ವಿರಿಂಚಃ",
        "ವಾಚಾಂ ನಿಧೇರ್ವಾಂಛಿತ ಭಾಗಧೇಯಃ",
        "ದೈತ್ಯಾಪನೀತಾನ್ ದಯಯೈನ ಭೂಯೋಽಪಿ",
        "ಅಧ್ಯಾಪಯಿಷ್ಯೋ ನಿಗಮಾನ್ನ ಚೇತ್ತ್ವಮ್ ||8||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವಿತರ್ಕಡೋಲಾಂ ವ್ಯವಧೂಯ ಸತ್ತ್ವೇ",
        "ಬೃಹಸ್ಪತಿಂ ವರ್ತಯಸೇ ಯತಸ್ತ್ವಂ",
        "ತೇನೈವ ದೇವ ತ್ರಿದೇಶೇಶ್ವರಾಣಾ",
        "ಅಸ್ಪೃಷ್ಟ ಡೋಲಾಯಿತ ಮಾಧಿರಾಜ್ಯಮ್ ||9||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅಗ್ನೌ ಸಮಿದ್ಧಾರ್ಚಿಷಿ ಸಪ್ತತಂತೋಃ",
        "ಆತಸ್ಥಿವಾನ್ ಮಂತ್ರಮಯಂ ಶರೀರಂ",
        "ಅಖಂಡಸಾರೈರ್ಹವಿಷಾಂ ಪ್ರದಾನೈಃ",
        "ಆಪ್ಯಾಯನಂ ವ್ಯೋಮಸದಾಂ ವಿಧತ್ಸೇ ||10||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಯನ್ಮೂಲ ಮೀದೃಕ್ ಪ್ರತಿಭಾತಿ ತತ್ತ್ವಂ",
        "ಯಾ ಮೂಲಮಾಮ್ನಾಯ ಮಹಾದ್ರುಮಾಣಾಂ",
        "ತತ್ತ್ವೇನ ಜಾನಂತಿ ವಿಶುದ್ಧ ಸತ್ತ್ವಾಃ",
        "ತ್ವಾಮಕ್ಷರಾಮಕ್ಷರ ಮಾತೃಕಾಂ ತ್ವಾಮ್ ||11||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅವ್ಯಾಕೃತಾತ್ ವ್ಯಾಕೃತವಾನಸಿ ತ್ವಂ",
        "ನಾಮಾನಿ ರೂಪಾಣಿ ಚ ಯಾನಿ ಪೂರ್ವಂ",
        "ಶಂಸಂತಿ ತೇಷಾಂ ಚರಮಾಂ ಪ್ರತಿಷ್ಠಾಂ",
        "ವಾಗೀಶ್ವರ ತ್ವಾಂ ತ್ವದುಪಜ್ಞ ವಾಚಃ ||12||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಮುಗ್ಧೇಂದು ನಿಷ್ಯಂದ ವಿಲೋಭನೀಯಾಂ",
        "ಮೂರ್ತಿಂ ತವಾನಂದ ಸುಧಾಪ್ರಸೂತಿಂ",
        "ವಿಪಶ್ಚಿತಶ್ಚೇತಸಿ ಭಾವಯಂತೇ",
        "ವೇಲಾಮುದಾರಾಮಿವ ದುಗ್ಧ ಸಿಂಧೋಃ ||13||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಮನೋಗತಂ ಪಶ್ಯತಿ ಯಃ ಸದಾ ತ್ವಾಂ",
        "ಮನೀಷಿಣಾಂ ಮಾನಸ ರಾಜಹಂಸಂ",
        "ಸ್ವಯಂಪುರೋಭಾವ ವಿವಾದ ಭಾಜಃ",
        "ಕಿಂಕುರ್ವತೇ ತಸ್ಯ ಗಿರೋ ಯಥಾರ್ಹಮ್ ||14||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅಪಿ ಕ್ಷಣಾರ್ಧಂ ಕಲಯಂತಿ ಯೇ ತ್ವಾಂ",
        "ಆಪ್ಲಾವಯಂತಂ ವಿಶದೈರ್ಮಯೂಖೈಃ",
        "ವಾಚಾಂ ಪ್ರವಾಹೈರನಿವಾರಿತೈಸ್ತೇ",
        "ಮಂದಾಕಿನೀಂ ಮಂದಯಿತುಂ ಕ್ಷಮಂತೇ ||15||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸ್ವಾಮಿನ್ ಭವದ್ದ್ಯಾನ ಸುಧಾಭಿಷೇಕಾತ್",
        "ವಹಂತಿ ಧನ್ಯಾಃ ಪುಲಕಾನು ಬಂದಂ",
        "ಅಲಕ್ಷಿತೇ ಕ್ವಾಪಿ ನಿರೂಢ ಮೂಲಂ",
        "ಅಂಗ್ವೇಷ್ವಿವಾನಂದ ಥುಮಂ ಕುರಂತಮ್ ||16||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸ್ವಾಮಿನ್ ಪ್ರತೀಚಾ ಹೃದಯೇನ ಧನ್ಯಾಃ",
        "ತ್ವದ್ಧ್ಯಾನ ಚಂದ್ರೋದಯ ವರ್ಧಮಾನಂ",
        "ಅಮಾಂತಮಾನಂದ ಪಯೋಧಿಮಂತಃ",
        "ಪಯೋಭಿ ರಕ್ಷ್ಣಾಂ ಪರಿವಾಹಯಂತಿ ||17||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸ್ವೈರಾನುಭಾವಾತ್ ತ್ವದಧೀನಭಾವಾಃ",
        "ಸಮೃದ್ಧವೀರ್ಯಾಃ ತ್ವದನುಗ್ರಹೇಣ",
        "ವಿಪಶ್ಚಿತೋನಾಥ ತರಂತಿ ಮಾಯಾಂ",
        "ವೈಹಾರಿಕೀಂ ಮೋಹನಪಿಂಛಿಕಾಂ ತೇ ||18||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪ್ರಾಙ್ನಿರ್ಮಿತಾನಾಂ ತಪಸಾಂ ವಿಪಾಕಾಃ",
        "ಪ್ರತ್ಯಗ್ರನಿಶ್ಶ್ರೇಯಸ ಸಂಪದೋ ಮೇ",
        "ಸಮೇಧಿಷೀರಂ ಸ್ತವ ಪಾದಪದ್ಮೇ",
        "ಸಂಕಲ್ಪಚಿಂತಾಮಣಯಃ ಪ್ರಣಾಮಾಃ ||19||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವಿಲುಪ್ತ ಮೂರ್ಧನ್ಯ ಲಿಪಿಕ್ರಮಾಣಾ",
        "ಸುರೇಂದ್ರ ಚೂಡಾಪದ ಲಾಲಿತಾನಾಂ",
        "ತ್ವದಂಘ್ರಿ ರಾಜೀವ ರಜಃ ಕಣಾನಾಂ",
        "ಭೂಯಾನ್ ಪ್ರಸಾದೋ ಮಯಿ ನಾಥ ಭೂಯಾತ್ ||20||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪರಿಸ್ಫುರನ್ನೂಪುರ ಚಿತ್ರಭಾನು -",
        "ಪ್ರಕಾಶನಿರ್ಧೂತ ತಮೋನುಷಂಗಾ",
        "ಪದದ್ವಯೀಂ ತೇ ಪರಿಚಿನ್ಮಹೇಽಂತಃ",
        "ಪ್ರಬೋಧ ರಾಜೀವ ವಿಭಾತಸಂಧ್ಯಾಮ್ ||21||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ತ್ವತ್ಕಿಂಕರಾ ಲಂಕರಣೋಚಿತಾನಾಂ",
        "ತ್ವಯೈವ ಕಲ್ಪಾಂತರ ಪಾಲಿತಾನಾಂ",
        "ಮಂಜುಪ್ರಣಾದಂ ಮಣಿನೂಪುರಂ ತೇ",
        "ಮಂಜೂಷಿಕಾಂ ವೇದಗಿರಾಂ ಪ್ರತೀಮಃ ||22||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸಂಚಿಂತಯಾಮಿ ಪ್ರತಿಭಾದಶಾಸ್ಥಾನ್",
        "ಸಂಧುಕ್ಷಯಂತಂ ಸಮಯಪ್ರದೀಪಾನ್",
        "ವಿಜ್ಞಾನ ಕಲ್ಪದ್ರುಮ ಪಲ್ಲವಾಭಂ",
        "ವ್ಯಾಖ್ಯಾನ ಮುದ್ರಾಮಧುರಂ ಕರಂ ತೇ ||23||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಚಿತ್ತೇ ಕರೋಮಿ ಸ್ಫುರಿತಾಕ್ಷ ಮಾಲಂ",
        "ಸವ್ಯೇತರಂ ನಾಥ ಕರಂ ತ್ವದೀಯಂ",
        "ಜ್ಞಾನಾಮೃತೋದಂಚನ ಲಾಲಸಾನಾಂ",
        "ಲೀಲಾಘಟೀಯಂತ್ರ ಮಿವಾಽಽಶ್ರಿತಾನಾಮ್ ||24||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪ್ರಬೋಧಸಿಂಧೋಃ ಅರುಣೈಃ ಪ್ರಕಾಶೈಃ",
        "ಪ್ರವಾಳಸಂಘಾತ ಮಿವೋದ್ವಹಂತಂ",
        "ವಿಭಾವಯೇ ದೇವ ಸ ಪುಸ್ತಕಂ ತೇ",
        "ವಾಮಂ ಕರಂ ದಕ್ಷಿಣ ಮಾಶ್ರಿತಾನಾಮ್ ||25||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ತಮಾಂಸಿ ಭಿತ್ತ್ವಾ ವಿಶದೈರ್ಮಯೂಖೈಃ",
        "ಸಂಪ್ರೀಣಯಂತಂ ವಿದುಷಶ್ಚಕೋರಾನ್",
        "ನಿಶಾಮಯೇ ತ್ವಾಂ ನವಪುಂಡರೀಕೇ",
        "ಶರದ್ಘನೇಚಂದ್ರಮಿವ ಸ್ಫುರಂತಮ್ ||26||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ದಿಶಂತು ಮೇ ದೇವ ಸದಾ ತ್ವದೀಯಾಃ",
        "ದಯಾತರಂಗಾನುಚರಾಃ ಕಟಾಕ್ಷಾಃ",
        "ಶ್ರೋತ್ರೇಷು ಪುಂಸಾಮಮೃತಂಕ್ಷರಂತೀಂ",
        "ಸರಸ್ವತೀಂ ಸಂಶ್ರಿತ ಕಾಮಧೇನುಮ್ ||27||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವಿಶೇಷವಿತ್ ಪಾರಿಷದೇಷು ನಾಥ",
        "ವಿದಗ್ಧಗೋಷ್ಠೀ ಸಮರಾಂಗಣೇಷು",
        "ಜಿಗೀಷತೋ ಮೇ ಕವಿತಾರ್ಕಿಕೇಂದ್ರಾನ್",
        "ಜಿಹ್ವಾಗ್ರ ಸಿಂಹಾಸನ ಮಭ್ಯುಪೇಯಾಃ ||28||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ತ್ವಾಂ ಚಿಂತಯನ್ ತ್ವನ್ಮಯತಾಂ ಪ್ರಪನ್ನಃ",
        "ತ್ವಾಮುದ್ಗೃಣನ್ ಶಬ್ದಮಯೇನ ಧಾಮ್ನಾ",
        "ಸ್ವಾಮಿನ್ ಸಮಾಜೇಷು ಸಮೇಧಿಷೀಯ",
        "ಸ್ವಚ್ಛಂದ ವಾದಾಹವ ಬದ್ಧಶೂರಃ ||29||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನಾನಾ ವಿಧಾನಾಂ ಅಗತಿಃ ಕಲಾನಾಂ",
        "ನ ಚಾಪಿ ತೀರ್ಥೇಷು ಕೃತಾವತಾರಃ",
        "ಧ್ರುವಂ ತವಾಽನಾಥ ಪರಿಗ್ರಹಾಯಾಃ",
        "ನವ ನವಂ ಪಾತ್ರಮಹಂ ದಯಾಯಾಃ ||30||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅಕಂಪನೀಯಾನ್ಯಪನೀತಿ ಭೇದೈಃ",
        "ಅಲಂಕೃಷೀರನ್ ಹೃದಯಂ ಮದೀಯಂ",
        "ಶಂಕಾ ಕಳಂಕಾ ಪಗಮೋಜ್ಜ್ವಲಾನಿ",
        "ತತ್ತ್ವಾನಿ ಸಮ್ಯಂಚಿ ತವ ಪ್ರಸಾದಾತ್ ||31||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವ್ಯಾಖ್ಯಾಮುದ್ರಾಂ ಕರಸರಸಿಜೈಃ ಪುಸ್ತಕಂ ಶಂಖಚಕ್ರೇ",
        "ಭಿಭ್ರದ್ಭಿನ್ನ ಸ್ಫಟಿಕರುಚಿರೇ ಪುಂಡರೀಕೇ ನಿಷಣ್ಣಃ |",
        "ಅಮ್ಲಾನಶ್ರೀರಮೃತವಿಶದೈಃ ಅಂಶುಭಿಃ ಪ್ಲಾವಯನ್ಮಾಂ",
        "ಆವಿರ್ಭೂಯಾದನಘ ಮಹಿಮಾ ಮಾನಸೇ ವಾಗಧೀಶಃ ||32||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವಾಗರ್ಥಸಿದ್ಧಿಹೇತೋಃ ಪಠತ ಹಯಗ್ರೀವ ಸಂಸ್ತುತಿಂ ಭಕ್ತ್ಯಾ",
        "ಕವಿತಾರ್ಕಿಕ ಕೇಸರಿಣಾ ವೇಂಕಟನಾಥೇನ ವಿರಚಿತಾಮೇತಾಮ್ ||33||"
