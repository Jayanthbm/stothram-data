{
  "title": "ಶ್ರೀ ಭೂಸ್ತುತಿಃ",
  "content": [
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರೀಮಾನ್ವೇಂಕಟನಾಥಾರ್ಯಃ ಕವಿತಾರ್ಕಿಕಕೇಸರಿ ।",
        "ವೇದಾಂತಾಚಾರ್ಯವರ್ಯೋ ಮೇ ಸನ್ನಿಧತ್ತಾಂ ಸದಾ ಹೃದಿ ॥1॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸಂಕಲ್ಪ ಕಲ್ಪಲತಿಕಾಮವಧಿಂ ಕ್ಷಮಾಯಾಃ",
        "ಸ್ವೇಚ್ಛಾ ವರಾಹಮಹಿಷೀಂ ಸುಲಭಾನುಕಂಪಾಂ ।",
        "ವಿಶ್ವಸ್ಯ ಮಾತರಮಕಿಂಚನ ಕಾಮಧೇನುಂ",
        "ವಿಶ್ವಂಭರಾಮಶರಣಃ ಶರಣಂ ಪ್ರಪದ್ಯೇ ॥2॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ತ್ವಾಂ ವ್ಯಾಹೃತಿಃ ಪ್ರಥಮತಃ ಪ್ರಣವಃ ಪ್ರಿಯಂ ತೇ",
        "ಸಂವೇದಯತ್ಯಖಿಲ ಮಂತ್ರಗಣಸ್ತಮೇವ ।",
        "ಇತ್ಥಂ ಪ್ರತೀತ ವಿಭವಾಮಿತರೇಷ್ವಿ ದಾನೀಂ",
        "ಸ್ತೋತುಂ ಯಥಾವದವನೇ ಕ ಇವಾಹರ್ತಿ ತ್ವಾಂ ॥3॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನಿತ್ಯಂ ಹಿತಾಹಿತ ವಿಪರ್ಯಾಯ ಬದ್ಧಭಾವೇ",
        "ತ್ವದ್ವೀಕ್ಷಣೈ ಕವಿನಿವೃತ್ತ ಬಹುವ್ಯಪಾಯೇ ।",
        "ಮುಗ್ಧಾ ಕ್ಷರೈರಖಿಲ ಧಾರಿಣಿ ಮೋದಮಾನಾ",
        "ಮಾತಃ ಸ್ತನಂಧಯಧಿಯಂ ಮಯಿ ವರ್ತಯೇಥಾಃ ॥4॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸಂಕಲ್ಪ ಕಿಂಕರ ಚರಾಚರ ಚಕ್ರವಾಳಂ",
        "ಸರ್ವಾರ್ಥ ಶಾಯಿನಮನಂತಶಯಸ್ಯ ಪುಂಸಃ ।",
        "ಭೂಮಾನ ಮಾತ್ಮವಿಭವೈಃ ಪುನರುಕ್ತಯಂತೀ",
        "ವಾಚಾಮ ಭೂಮಿರಪಿ ಭೂಮಿರಸಿ ತ್ವಮೇಕಾ ॥5॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅಂಬ ತ್ವದಾಶ್ರಿತತಯಾ ಪರಿಪೋಷಯಂತೀ",
        "ವಿಶ್ವಂಭರಸ್ಯ ದಯಿತಾಸಿ ತದೇಕನಾಮಾ ॥6॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸರ್ವಂ ಸಹೇತ್ಯವನಿರಿತ್ಯಚಲೇತಿ ಮಾತಃ",
        "ವಿಶ್ವಂಭರೇತಿ ವಿಪುಲೇತಿ ವಸುಂಧರೇತಿ ।",
        "ಅನ್ಯಾನಿ ಚಾನ್ಯ ವಿಮುಖಾನ್ಯಭಿ ಧಾನವೃತ್ತಾ",
        "ನಾಮಾನ್ಯಮೂನಿ ಕಥಯಂತಿ ತವಾನುಭಾವಂ ॥7॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ತಾಪಾನ್ ಕ್ಷಿಪನ್ ಪ್ರಸವಿತಾ ಸುಮನೋಗಣಾನಾಂ",
        "ಪ್ರಚ್ಛಾಯ ಶೀತಳತಲಃ ಪ್ರದಿಶನ್ ಫಲಾನಿ ।",
        "ತ್ವತ್ಸಂಗ ಮಾದ್ಭವತಿ ಮಾಧವಿ ಲಬ್ಧಪೋಷಃ",
        "ಶಾಖಾಶತೈರಧಿಗತೋ ಹರಿಚಂದನೋಽಸೌ ॥8॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸ್ಮೇರೇಣ ವಧಿರ್ತರಸಸ್ಯ ಮುಖೇಂದುನಾ ತೇ",
        "ನಿಸ್ಪಂದತಾಂ ವಿಜಹತೋ ನಿಜಯಾ ಪ್ರಕೃತ್ಯಾ ।",
        "ವಿಶ್ರಾಂತಿ ಭೂಮಿರಸಿ ತತ್ತ್ವತ ರಂಗಪಂಕ್ತೇಃ",
        "ವೇಲೇವ ವಿಷ್ಣು ಜಲಧೇರಪೃಥಗ್ಭವಂತೀ ॥9॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸ್ವಾಭಾವಿಕೇ ವಸುಮತಿ ಶ್ರುತಿಭಿರ್ಭಾವ್ಯೇ",
        "ಪತ್ಯುರ್ಮಹಿಮ್ನಿ ಭವತೀಂ ಪ್ರತಿಪನ್ನವಾಸಾಂ ।",
        "ಶಂಕೇ ವಿಮಾನ ವಹನ ಪ್ರತಿಮಾಸ ಮಾನಾಃ",
        "ಸ್ತಂಬೇರಮಪ್ರಭೃತಯೋಽಪಿ ವಹಂತಿ ಸತ್ತ್ವಾಃ ॥10॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸಂಭಾವಯನ್ ಮಧುರಿಪುಃ ಪ್ರಣಯಾನುಬಂಧಾತ್",
        "ವಕ್ಷಃಸ್ಥಲೇನ ವರುಣಾಲಯ ರಾಜಕನ್ಯಾಂ ।",
        "ವಿಶ್ವಂಭರೇ ಬಹುಮುಖ ಪ್ರತಿಪನ್ನಭೋಗಃ",
        "ಶೇಷಾತ್ಮನಾ ತು ಭವತೀಂ ಶಿರಸಾ ದಧಾತಿ ॥11॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಆಮೋದಯಂತಿ ಭುವನಾನ್ಯಳಿಕಾಶ್ರಿತಾನಾಂ",
        "ಅಂಬ ತ್ವದಂಘ್ರಿರಜಸಾಂ ಪರಿನಾಮಭೇದೈಃ ॥12॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಭೂತೇಷು ಯತ್ ತ್ವದಭಿಮಾನ ವಿಶೇಷಪಾತ್ರಂ",
        "ಪೋಷಂ ತದೇವ ಭಜತೀತಿ ವಿಭಾವಯಂತಃ ।",
        "ಭೂತಂ ಪ್ರಭೂತ ಗುಣಪಂಚಕ ಮಾದ್ಯಮೇತತ್",
        "ಪ್ರಾಯೋ ನಿದರ್ಶನತಯಾ ಪ್ರತಿಪಾದಯಂತಿ ॥13॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕಾಂತಸ್ತವೈಷ ಕರುಣಾಜಲಧಿಃ ಪ್ರಜಾನಾಂ",
        "ಆಜ್ಞಾತಿ ಲಂಘನವಶಾದುಪಜಾತರೋಷಃ ।",
        "ಅಹ್ನಾಯ ವಿಶ್ವಜನನಿ ಕ್ಷಮಯಾ ಭವತ್ಯಾ",
        "ಸರ್ವಾರ್ಥ ವಹನ ಸಹಾಮುಪಯಾತ್ಯವಸ್ಥಾಂ ॥14॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಆಶ್ವಾಸನಾಯ ಜಗತಾಂ ಪುರುಷೇ ಪರಸ್ಮಿನ್",
        "ಆಪನ್ನ ರಕ್ಷಣ ದಶಾಮಭಿನೇತು ಕಾಮೇ ।",
        "ಅಂತರ್ಹಿತೇತರ ಗುಣಾದ ಬಲಸ್ವಭಾವಾತ್",
        "ಔದನ್ವತೇ ಪಯಸಿ ಮಜ್ಜನಮಭ್ಯನೇಷೀಃ ॥15॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪೂರ್ವಂ ವರಾಹ ವಪುಷಾ ಪುರುಷೋತ್ತಮೇನ",
        "ಪ್ರೀತೇನ ಭೋಗಿಸದನೇ ಸಮುದೀಕ್ಷಿತಾಯಾಃ ।",
        "ಪಾದಾಹತಾಃ ಪ್ರಳಯ ವಾರಿಧಯಸ್ತವಾಸನ್",
        "ಉದ್ಧ್ವಾಹ ಮಂಗಳವಿಧೇ ರುಚಿತಾ ಮೃದಂಗಾಃ ॥16॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವ್ಯೋಮಾತಿ ಲಂಘಿನಿ ವಿಭೋಃ ಪ್ರಳಯಾಂಬುರಾಶೌ",
        "ವೇಶಂತಲೇಶ ಇವ ಮಾತುಮಶಕ್ಯಮೂರ್ತೇಃ ।",
        "ಸದ್ಯಃ ಸಮುದ್ರವಸನೇ ಸರಸೈರಕಾಶೀಃ",
        "ಆನಂದ ಸಾಗರಮಪಾರಮಪಾಂಗಪಾತೈಃ ॥17॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ದಂಷ್ಟ್ರಾ ವಿದಾರಿತ ಮಹಾಸುರ ಶೋಣಿತಾಂಕೈಃ",
        "ಅಂಗೈಃ ಪ್ರಿಯಸ್ತವ ದಧೇ ಪರಿರಂಭ ಲೀಲಾಂ ।",
        "ಸಾ ತೇ ಪಯೋಧಿ ಜಲಕೇಳಿ ಸಮುತ್ಥಿತಾಯಾಃ",
        "ಸೈರಂಧ್ರಿಕೇವ ವಿದಧೇ ನವಮಂಗರಾಗಂ ॥18॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅನ್ಯೋನ್ಯ ಸಂವಲನ ಜೃಂಭಿತ ತೂರ್ಯಘೋಷೈಃ",
        "ಸಂವರ್ತ ಸಿಂಧುಸಲಿಲೈರ್ವಿಹಿತಾಭಿಷೇಕಾ ।",
        "ಏಕಾತಪತ್ರಯಸಿ ವಿಶ್ವಮಿದಂ ಗುಣೈಃ ಸ್ವೈಃ",
        "ಅಧ್ಯಾಸ್ಯ ಭರ್ತುರಧಿಕೋನ್ನತಮಂಸಪೀಠಂ ॥19॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಭರ್ತುರ್ತಮಾಲರುಚಿರೇ ಭುಜಮಧ್ಯಭಾಗೇ",
        "ಪರ್ಯಂತ ಮೌಕ್ತಿಕವತೀ ಪೃಷತೈಃ ಪಯೋಧೇಃ ।",
        "ತಾಪಾನುಬಂಧ ಶಮನೀ ಜಗತಾಂ ತ್ರಯಾಣಾಂ",
        "ತಾರಾಪಥೇ ಸು್ಫರಸಿ ತಾರಕಿತಾ ನಿಶೇವ ॥20॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಆಸಕ್ತ ವಾಸವ ಶರಾಸನ ಪಲ್ಲವೈಸ್ತ್ವಾಂ",
        "ಸಂವೃದ್ಧಯೇ ಶುಭತಟಿದ್ಗಣಜಾಲರಮ್ಯೈಃ ।",
        "ದೇವೇಶ ದಿವ್ಯಮಹಿಷೀಂ ಧೃತಸಿಂಧು ತೋಯೈಃ",
        "ಜೀಮೂತ ರತ್ನಕಲಶೈರಭಿಷಿಂಚತಿ ದ್ಯೌಃ ॥21॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಆವಿಮರ್ದೈರಮರದಂತಿಭಿರುಹ್ಯಮಾನಾಂ",
        "ರತ್ನಾಕರೇಣ ರುಚಿರಾಂ ರಶನಾಗುಣೇನ ।",
        "ಮಾತಸ್ತ್ರಿಲೋಕಜನನೀಂ ವನಮಾಲಿನೀಂ ತ್ವಾಂ",
        "ಮಾಯಾ ವರಾಹಮಹಿಷೀಮವಯಂತಿ ಸಂತಃ ॥22॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನಿಷ್ಕಂಟಕ ಪ್ರಶಮಯೋಗ ನಿಷೇವಣೀಯಾಂ",
        "ಛಾಯಾ ವಿಶೇಷಪರಿಭೂತ ಸಮಸ್ತತಾಪಾಂ ।",
        "ಸ್ವರ್ಗಾಪವರ್ಗ ಸರಣಿಂ ಭವತೀಮುಶಂತಿ",
        "ಸ್ವಚ್ಛಂದ ಸೂಕರವಧೂಮವಧೂತಪಂಕಾಂ ॥23॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಗಂಡೋಜ್ಜ್ವಲಾಂ ಗಹನಕುಂತಳ ದರ್ಶನೀಯಾಂ",
        "ಶೈಲಸ್ತನೀಂ ತರಳ ನಿಝರ್ರಲಂಬಹಾರಾಂ ।",
        "ಶ್ಯಾಮಾಂ ಸ್ವತಸ್ತ್ರಿಯುಗ ಸೂಕರಗೇಹಿನಿ ತ್ವಂ",
        "ವ್ಯಕ್ತಿಂ ಸಮುದ್ರವಸನಾಮುಭಯೀಂ ಬಿಭರ್ಷಿ ॥24॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ನಿಃಸಂಶಯೈ ನಿರ್ಗಮಸೀಮನಿ ವಿಷ್ಣುಪತ್ನಿ",
        "ಪ್ರಖ್ಯಾಪಿತಂ ಭೃಗುಮುಖೈರ್ಮುನಿಭಿಃ ಪ್ರತೀತೈಃ ।",
        "ಪಶ್ಯಂತ್ಯನನ್ಯ ಪರಧೀರಸ ಸಂಸ್ಕೃತೇನ",
        "ಸಂತಃ ಸಮಾಧಿನಯನೇನ ತವಾನುಭಾವಂ ॥25॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸಂಚೋದಿತಾ ಕರುಣಯಾ ಚತುರಃ ಪುಮರ್ಥಾನ್",
        "ವ್ಯಾತನ್ವತೀ ವಿವಿಧ ಮಂತ್ರಗಣೋಪಗೀತಾ ।",
        "ಸಂಚಿಂತ್ಯಸೇ ವಸುಮತಿ ಸ್ಥಿರಭಕ್ತಿಬಂಧೈಃ",
        "ಅಂತರ್ಬಹಿಶ್ಚ ಬಹುಧಾ ಪ್ರಣಿಧಾನದಕ್ಷೈಃ ॥26॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕ್ರೀಡಾ ಗೃಹೀತ ಕಮಲಾದಿ ವಿಶೇಷಚಿಹ್ನಾಂ",
        "ವಿಶ್ರಾಣಿತಾ ಭಯಕರಾಂ ವಸುಧೇ ಸಭೂತಿಂ ।",
        "ದೌರ್ಗತ್ಯ ದುರ್ವಿಷ ವಿನಾಶ ಸುಧಾನದೀಂ ತ್ವಾಂ",
        "ಸಂಚಿಂತಯನ್ ಹಿ ಲಭತೇ ಧನದಾಧಿಕಾರಂ ॥27॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಉದ್ವೇಲ ಕಲ್ಮಷಪರಂ ಪರಿತಾದಮರ್ಷಾತ್",
        "ಉತ್ತಂಸಿತೇನ ಹರಿಮಂಜಲಿನಾಪ್ಯಧೃಷ್ಯಂ ।",
        "ಆಕಸ್ಮಿಕೋಽಯಮಧಿಗಮ್ಯಯತಿ ಪ್ರಜಾನಾಂ",
        "ಅಂಬ ತ್ವದೀಯಕರುಣಾ ಪರಿಣಾಮ ಏವ ॥28॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪ್ರತ್ಯೇಕಮಬ್ದನಿಯುತೈರಪಿ ದುರ್ಯವಹಾತ್",
        "ಪ್ರಾಪ್ತೇ ವಿಪಾಕಸಮಯೇ ಜನಿತಾನುತಾಪಾತ್ ।",
        "ನಿತ್ಯಾಪರಾಧ ನಿವಹಾಚ್ಚ ಕಿತಸ್ಯ ಜನ್ತೋಃ",
        "ಗಂತುಂ ಮುಕುಂದಚರಣೌ ಶರಣಂ ಕ್ಷಮೇ ತ್ವಂ ॥29॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ತ್ರಾಣಾಭಿ ಸಂಧಿಸುಭಗೇಽಪಿ ಸದಾ ಮುಕುಂದೇ",
        "ಸಂಸಾರ ತಂತ್ರವಹನೇನ ವಿಳಂಬಮಾನೆ ।",
        "ರಕ್ಷಾವಿಧೌ ತನುಭೃತಾಮನಘಾನುಕಂಪಾ",
        "ಮಾತಃ ಸ್ವಯಂ ವಿತನುಷೇ ಮಹತೀಮಪೇಕ್ಷಾಂ ॥30॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಧರ್ಮದ್ರುಹಂ ಸಕಲದುಷ್ಕೃತಿ ಸಾರ್ವಭೌಮಂ",
        "ಆತ್ಮಾನಭಿಜ್ಞಮನುತಾಪಲವೋಜ್ಝಿತಂ ಮಾಂ ।",
        "ವೈತಾನಸೂಕರಪತೇಶ್ಚರಣಾರವಿಂದೇ",
        "ಸರ್ವಂಸಹೇ ನನು ಸಮರ್ಪಯಿತುಂ ಕ್ಷಮಾ ತ್ವಂ ॥31॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ತಾಪತ್ರಯೀಂ ನಿರವಧಿಂ ಭವತೀದಯಾದ್ರಾಃ",
        "ಸಂಸಾರ ಘರ್ಮಜನಿತಾಂ ಸಪದಿ ಕ್ಷಿಪಂತಃ ।",
        "ಮಾತರ್ಭಜಂತು ಮಧುರಾಮೃತವರ್ಷಮೈತ್ರೀಂ",
        "ಮಾಯಾ ವರಾಹದಯಿತೇ ಮಯಿ ತೇ ಕಟಾಕ್ಷಾಃ ॥32॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪತ್ಯರ್ಧ ಕ್ಷಣಪಾಣಿಪಂಕಜಪುಟೇ ವಿನ್ಯಸ್ತಪಾದಾಂಬುಜಾ",
        "ವಾಮಂ ಪನ್ನಗ ಸಾರ್ವಭೌಮಸದೃಶಂ ಪರ್ಯಂಕಯಂತೀ ಭುಜಂ ।",
        "ವಕ್ತ್ರಸ್ಪರ್ಶಲಸತ್ಕಪೋಲ ಫಲಕಾ ಫುಲ್ಲಾರವಿಂದೇಕ್ಷಣಾ",
        "ಸಾ ಮೇ ಪುಷ್ಯತು ಮಂಗಳಾನ್ಯನುದಿನಂ ಸರ್ವಾಣಿ ಸರ್ವಂಸಹಾ ॥33॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಅಸ್ಯೇಶಾನಾ ಜಗತ ಇತಿ ಯಾ ಶ್ರೂಯತೇ ವಿಷ್ಣುಪತ್ನೀ",
        "ತಸ್ಯಾಃ ಸ್ತೋತ್ರಂ ವಿರಚಿತಮಿದಂ ವೇಂಕಟೇಶೇನ ಭಕ್ತ್ಯಾ ।",
        "ಶ್ರದ್ಧಾಭಕ್ತಿ ಪ್ರಚಯಗುರುಣಾ ಚೇತಸಾ ಸಂಸ್ತುವಾನಃ",
        "ಯದ್ಯತ್ಕಾಮ್ಯಂ ಸಪದಿ ಲಭತೇ ತತ್ರ ತತ್ರ ಪ್ರತಿಷ್ಠಾಂ ॥"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಕವಿತಾರ್ಕಿಕಸಿಂಹಾಯ ಕಲ್ಯಾಣಗುಣಶಾಲಿನೇ ।",
        "ಶ್ರೀಮತೇ ವೇಂಕಟೇಶಾಯ ವೇದಾಂತಗುರವೇ ನಮಃ ॥"
      ]
    }
  ]
}
