{
  "title": "ಮಂಗಲಂ ಕೋಸಲೇಂದ್ರಾಯ(ರಾಮ ಮಂಗಲಂ)",
  "fonts": {
    "subheading": "NotoSans",
    "paragraph": "NudiParijathaBold"
  },
  "content": [
    {
      "type": "paragraph",
      "lines": [
        "ಮಂಗಲಂ ಕೋಸಲೇಂದ್ರಾಯ ಮಹನೀಯ ಗುಣಾಬ್ಧಯೆ|",
        "ಚಕ್ರವರ್ತೀ ತನೂಜಾಯ ಸಾರ್ವಭೌಮಾಯ ಮಂಗಲಂ ||"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವೇದವೇದಾಂತ ವೇದ್ಯಾಯ ಮೇಘಶ್ಯಾಮಲ ಮೂರ್ತಯೇ",
        "ಪುಂಸಾಂ ಮೋಹನರೂಪಾಯ ಪುಣ್ಯಶ್ಲೋಕಾಯ ಮಂಗಲಂ |"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ವಿಶ್ವಾಮಿತ್ರಾಂತರಂಗಾಯ ಮಿಥಿಲಾ ನಗರೀಪತೇ",
        "ಭಾಗ್ಯಾನಾಂ ಪರಿಪಾಕಾಯ ಭವ್ಯರೂಪಾಯ ಮಂಗಲಂ|"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಪಿತೃಭಕ್ತಾಯ ಸತತಂ ಭ್ರಾತೃಭಿಃ ಸಹ ಸೀತಯಾ",
        "ನಂದಿತಾಖಿಲ ಲೋಕಾಯ ರಾಮಭದ್ರಾಯ ಮಂಗಲಂ|"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ತೃಕ್ತ ಸಾಕೇತ ವಾಸಾಯ ಚಿತ್ರಕೂಟವಿಹಾರಿಣೇ ",
        "ಸೇವ್ಯಾಯ ಸರ್ವಯಮಿನಾಂ ಧೀರೋಧಾರಾಯ ಮಂಗಲಂ |"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸೌಮಿತ್ರಿಣಾ ಚ ಜಾನಕ್ಯಾ ಚಾಪ ಬಾಣಾಸಿ ಧಾರಿಣೇ",
        "ಸಂಸೇವ್ಯಾಯ ಸದಾ ಭಕ್ತ್ಯಾ ಸ್ವಾಮಿನೇ ಮಮ ಮಂಗಲಂ |"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ದಂಡಕಾರಣ್ಯ ವಾಸಾಯ ಖಂಡಿತಾಮರಶತ್ರವೇ",
        "ಗೃಧ್ರರಾಜಾಯ ಭಕ್ತಾಯ ಮುಕ್ತಿದಾಯಾಸ್ತು ಮಂಗಲಂ"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಸಾದರಂ ಶಬರೀದತ್ತ ಫಲ ಮೂಲಾಭಿಲಾಷಿಣೇ",
        "ಸೌಲಭ್ಯ ಪರಿಪೂರ್ಣಾಯ ಸತ್ವೋದ್ರಿಕ್ತಾಯ ಮಂಗಲಂ|"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಹನುಮತ್ಸಮವೇತಾಯ ಹರೀಶಾಭೀಷ್ಟದಾಯಿನೇ ",
        "ವಾಲಿಪ್ರಮಥನಾಯಾಸ್ತು ಮಹಾಧೀರಾಯ ಮಂಗಲಂ|"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಶ್ರೀಮತೇ ರಘುವೀರಾಯ ಸೇತೂಲ್ಲಂಘಿತ ಸಿಂಧವೇ",
        "ಜಿತರಾಕ್ಷಸ ರಾಜಾಯ ರಣಧೀರಾಯ ಮಂಗಲಂ|"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "*ಆಸಾದ್ಯ ನಗರೀಂ ದಿವ್ಯಾಂ ಅಭಿಷಿಕ್ತಾಯ ಸೀತಯಾ",
        "ರಾಜಾಧಿರಾಜರಾಜಾಯ ರಾಮಭದ್ರಾಯ ಮಂಗಲಂ|"
      ]
    },
    {
      "type": "paragraph",
      "lines": [
        "ಮಕ್ಕಳಾ ಶಾಸನಪರೈರ್ಮದಾಚಾರ್ಯ ಪುರೋಗಮೈ:",
        "ಸರ್ವೈಶ್ಚ ಪೂರ್ವೈರಾಚಾರ್ಯೈ: ಸತ್ಕೃತಾಯಾಸ್ತು ಮಂಗಲಂ |"
      ]
    }
  ]
}
